<link rel="stylesheet" href="/css/cascade-builder.css">

<div class="builder-shell">
    <section class="builder-hero">
        <div class="builder-hero-copy">
            <span class="builder-eyebrow"><%= t('cascades.builderEyebrow') %></span>
            <h2 class="builder-title"><%= t('cascades.builderTitle') %></h2>
            <p class="builder-subtitle"><%= t('cascades.builderSubtitle') %></p>
            <div class="builder-meta-note">
                <i class="ti ti-git-branch"></i>
                <span id="builderSourceMeta"><%= t('cascades.builderSourceMeta') %></span>
            </div>
        </div>
        <div class="builder-hero-actions">
            <button class="btn btn-secondary" id="builderAutoLayout">
                <i class="ti ti-layout-distribute-horizontal"></i>
                <span><%= t('cascades.autoLayout') %></span>
            </button>
            <button class="btn btn-secondary" id="builderFitView">
                <i class="ti ti-focus-2"></i>
                <span><%= t('cascades.fitView') %></span>
            </button>
            <button class="btn btn-secondary" id="builderSaveLayout">
                <i class="ti ti-device-floppy"></i>
                <span><%= t('cascades.saveLayout') %></span>
            </button>
            <button class="btn btn-secondary" id="builderCommitDrafts">
                <i class="ti ti-git-merge"></i>
                <span><%= t('cascades.commitDrafts') %></span>
            </button>
            <button class="btn btn-secondary" id="builderCommitDeploy">
                <i class="ti ti-player-play"></i>
                <span><%= t('cascades.commitAndDeploy') %></span>
            </button>
            <button class="btn btn-secondary" id="builderDeployPreview">
                <i class="ti ti-scan-eye"></i>
                <span><%= t('cascades.deployPreview') %></span>
            </button>
            <button class="btn btn-primary" id="builderValidate">
                <i class="ti ti-checkup-list"></i>
                <span><%= t('cascades.validateDraft') %></span>
            </button>
        </div>
    </section>

    <section class="builder-summary" id="builderSummary">
        <div class="builder-summary-item">
            <span class="builder-summary-label"><%= t('cascades.summaryNodes') %></span>
            <strong id="summaryNodes">0</strong>
        </div>
        <div class="builder-summary-item">
            <span class="builder-summary-label"><%= t('cascades.summaryHops') %></span>
            <strong id="summaryHops">0</strong>
        </div>
        <div class="builder-summary-item">
            <span class="builder-summary-label"><%= t('cascades.summaryStatus') %></span>
            <strong id="summaryStatus">—</strong>
        </div>
        <div class="builder-summary-item">
            <span class="builder-summary-label"><%= t('cascades.summaryWarnings') %></span>
            <strong id="summaryWarnings">0</strong>
        </div>
    </section>

    <section class="builder-workspace">
        <aside class="builder-library">
            <div class="builder-panel-head">
                <h3><%= t('cascades.libraryTitle') %></h3>
                <p><%= t('cascades.libraryHint') %></p>
            </div>
            <div class="builder-library-list" id="builderNodeLibrary"></div>
        </aside>

        <div class="builder-canvas-wrap">
            <div class="builder-canvas-toolbar">
                <div class="builder-canvas-hint">
                    <i class="ti ti-route-2"></i>
                    <span><%= t('cascades.dragHint') %></span>
                </div>
                <div class="builder-canvas-actions">
                    <button class="btn btn-secondary btn-sm" id="builderResetDrafts">
                        <i class="ti ti-eraser"></i>
                        <span><%= t('cascades.resetDrafts') %></span>
                    </button>
                    <a class="btn btn-secondary btn-sm" href="/panel/nodes">
                        <i class="ti ti-topology-star-3"></i>
                        <span><%= t('cascades.openLegacyMap') %></span>
                    </a>
                </div>
            </div>
            <div id="builderCy" class="builder-canvas"></div>
        </div>

        <aside class="builder-inspector">
            <div class="builder-panel-head">
                <h3><%= t('cascades.inspectorTitle') %></h3>
                <p><%= t('cascades.inspectorHint') %></p>
            </div>
            <div class="builder-inspector-body" id="builderInspectorBody">
                <div class="builder-empty-state">
                    <i class="ti ti-pointer"></i>
                    <p><%= t('cascades.inspectorEmpty') %></p>
                </div>
            </div>
            <div class="builder-validation-box" id="builderValidationBox">
                <div class="builder-validation-head">
                    <h4><%= t('cascades.validationTitle') %></h4>
                    <span class="builder-validation-badge" id="builderValidationBadge">—</span>
                </div>
                <div class="builder-validation-list" id="builderValidationList">
                    <p class="builder-validation-empty"><%= t('cascades.validationEmpty') %></p>
                </div>
            </div>
            <div class="builder-validation-box builder-plan-box" id="builderPlanBox">
                <div class="builder-validation-head">
                    <h4><%= t('cascades.deployPreviewTitle') %></h4>
                    <span class="builder-validation-badge" id="builderPlanBadge">—</span>
                </div>
                <div class="builder-plan-list" id="builderPlanList">
                    <p class="builder-validation-empty"><%= t('cascades.deployPreviewEmpty') %></p>
                </div>
            </div>
            <div class="builder-validation-box builder-execution-box" id="builderExecutionBox">
                <div class="builder-validation-head">
                    <h4><%= t('cascades.executionTitle') %></h4>
                    <div class="builder-validation-head-actions">
                        <button class="btn btn-secondary btn-sm" id="builderExecutionCopy" type="button">
                            <i class="ti ti-copy"></i>
                            <span><%= t('cascades.executionCopy') %></span>
                        </button>
                        <span class="builder-validation-badge" id="builderExecutionBadge">—</span>
                    </div>
                </div>
                <div class="builder-plan-list builder-execution-list" id="builderExecutionList">
                    <p class="builder-validation-empty"><%= t('cascades.executionEmpty') %></p>
                </div>
            </div>
        </aside>
    </section>
</div>

