<%
const totalTrafficGB = (stats.traffic?.total || 0) / (1024 * 1024 * 1024);
const totalTxGB = (stats.traffic?.tx || 0) / (1024 * 1024 * 1024);
const totalRxGB = (stats.traffic?.rx || 0) / (1024 * 1024 * 1024);
const trafficWindowTotalGB = (stats.trafficWindow?.total || 0) / (1024 * 1024 * 1024);
const trafficWindowTxGB = (stats.trafficWindow?.tx || 0) / (1024 * 1024 * 1024);
const trafficWindowRxGB = (stats.trafficWindow?.rx || 0) / (1024 * 1024 * 1024);
const formatTrafficDashboard = (gb) => {
    if (gb >= 1000) {
        return (gb / 1024).toFixed(2) + ' TB';
    }
    return gb.toFixed(1) + ' GB';
};
const formatTrafficWindowValue = (bytes) => {
    const kb = bytes / 1024;
    const mb = bytes / (1024 * 1024);
    const gb = bytes / (1024 * 1024 * 1024);
    if (gb >= 1) return gb.toFixed(2) + ' GB';
    if (mb >= 1) return mb.toFixed(1) + ' MB';
    if (kb >= 1) return kb.toFixed(0) + ' KB';
    return Math.max(bytes, 0).toFixed(0) + ' B';
};
const formatTrafficPeriodLabel = (period) => {
    switch (period) {
        case '24h': return t('dashboard.traffic24h');
        case '7d': return t('dashboard.traffic7d');
        case '30d': return t('dashboard.traffic30d');
        default: return t('dashboard.trafficLive');
    }
};
const nodeHealthPct = stats.nodes.total ? Math.round((stats.nodes.online / stats.nodes.total) * 100) : 0;
const userHealthPct = stats.users.total ? Math.round((stats.users.enabled / stats.users.total) * 100) : 0;
const sparklinePoints = (stats.trafficWindow?.points || []).length
    ? stats.trafficWindow.points.map((point) => ({
        label: point.label,
        raw: point.value || 0,
        display: formatTrafficWindowValue(point.value || 0)
    }))
    : [{ label: '—', raw: 0, display: '0 B' }, { label: '—', raw: 1, display: '1 B' }];
const limitedDeviceCapacity = stats.devices?.capacity || 0;
const activeDevices = stats.devices?.activeDevices || 0;
const activeProfiles = stats.devices?.activeProfiles || 0;
const activeProfilePct = stats.users.enabled ? Math.min(100, Math.round((activeProfiles / stats.users.enabled) * 100)) : 0;
const deviceUsagePct = limitedDeviceCapacity
    ? Math.min(100, Math.round((activeDevices / limitedDeviceCapacity) * 100))
    : Math.min(100, Math.max(activeProfiles ? 100 : 0, Math.round((activeProfiles / Math.max(stats.users.enabled, 1)) * 100)));
%>

<section class="experience-hero dashboard-hero">
    <div class="hero-copy">
        <span class="hero-eyebrow"><%= t('dashboard.heroEyebrow') %></span>
        <h2><%= t('dashboard.title') || t('nav.dashboard') %></h2>
        <p>
            <%= t('dashboard.heroDescription') %>
        </p>
        <div class="hero-action-row">
            <a href="/panel/nodes/add" class="btn btn-primary">
                <i class="ti ti-server-2"></i> <%= t('dashboard.addNode') %>
            </a>
            <a href="/panel/users/add" class="btn btn-secondary">
                <i class="ti ti-user-plus"></i> <%= t('dashboard.addUser') %>
            </a>
            <a href="/panel/stats" class="hero-link-chip">
                <i class="ti ti-chart-line"></i> <span><%= t('nav.stats') %></span>
            </a>
        </div>
    </div>
    <div class="hero-metrics">
        <div class="hero-meter-card">
            <div class="hero-meter-ring" style="--meter-value:<%= nodeHealthPct %>;">
                <span><%= nodeHealthPct %>%</span>
            </div>
            <div class="hero-meter-copy">
                <strong><%= t('dashboard.nodesHealthy') %></strong>
                <span><%= stats.nodes.online %> / <%= stats.nodes.total %> <%= t('dashboard.nodesHealthyHint') %></span>
            </div>
        </div>
        <div class="hero-meter-card">
            <div class="hero-meter-ring soft" style="--meter-value:<%= userHealthPct %>;">
                <span><%= userHealthPct %>%</span>
            </div>
            <div class="hero-meter-copy">
                <strong><%= t('nav.users') %></strong>
                <span><%= stats.users.enabled %> <%= t('common.of') %> <%= stats.users.total %> <%= t('dashboard.usersEnabledHint') %></span>
            </div>
        </div>
        <div class="hero-sparkline-card">
            <div class="sparkline-copy">
                <span class="sparkline-title" data-sparkline-title><%= formatTrafficPeriodLabel(stats.trafficWindow?.period) %></span>
                <strong><%= formatTrafficDashboard(trafficWindowTotalGB) %></strong>
                <div class="sparkline-periods" role="group" aria-label="Traffic period">
                    <button type="button" class="sparkline-period-btn" data-sparkline-period="24h">24ч</button>
                    <button type="button" class="sparkline-period-btn active" data-sparkline-period="7d">7д</button>
                    <button type="button" class="sparkline-period-btn" data-sparkline-period="30d">30д</button>
                </div>
            </div>
            <div
                class="sparkline-visual interactive"
                data-sparkline-chart
                data-period="<%= stats.trafficWindow?.period || '7d' %>"
                data-points='<%- JSON.stringify(sparklinePoints) %>'
                aria-label="<%= t('dashboard.trafficChart') %>"
            >
                <svg class="sparkline-svg" viewBox="0 0 320 152" preserveAspectRatio="none" aria-hidden="true">
                    <defs>
                        <linearGradient id="trafficLineFill" x1="0" x2="0" y1="0" y2="1">
                            <stop offset="0%" stop-color="rgba(8,197,203,0.18)"></stop>
                            <stop offset="100%" stop-color="rgba(8,197,203,0.02)"></stop>
                        </linearGradient>
                    </defs>
                    <path class="sparkline-area" d=""></path>
                    <path class="sparkline-line" d=""></path>
                    <g class="sparkline-points"></g>
                    <g class="sparkline-focus" hidden>
                        <line class="sparkline-focus-line" x1="0" y1="16" x2="0" y2="132"></line>
                        <circle class="sparkline-focus-dot" cx="0" cy="0" r="5"></circle>
                    </g>
                </svg>
                <div class="sparkline-tooltip" hidden>
                    <span class="sparkline-tooltip-label"></span>
                    <strong class="sparkline-tooltip-value"></strong>
                </div>
            </div>
            <div class="sparkline-foot">
                <span><i class="ti ti-arrow-up-right"></i> <%= formatTrafficDashboard(trafficWindowTxGB) %></span>
                <span><i class="ti ti-arrow-down-right"></i> <%= formatTrafficDashboard(trafficWindowRxGB) %></span>
            </div>
        </div>
        <div class="hero-mini-card hero-device-card">
            <div class="hero-device-rings">
                <div class="hero-meter-ring mini" style="--meter-value:<%= activeProfilePct %>;">
                    <span><%= activeProfiles %></span>
                </div>
                <div class="hero-meter-ring mini soft" style="--meter-value:<%= deviceUsagePct %>;">
                    <span><%= activeDevices %></span>
                </div>
            </div>
            <div class="hero-meter-copy">
                <strong><%= t('dashboard.profilesAndDevices') %></strong>
                <span><%= activeProfiles %> <%= t('dashboard.activeProfilesHint') %> <%= stats.users.enabled %></span>
                <span>
                    <%= activeDevices %> <%= t('dashboard.devices') %>
                    <% if (limitedDeviceCapacity) { %>
                        / <%= limitedDeviceCapacity %> <%= t('dashboard.available') %>
                    <% } else { %>
                        • <%= t('dashboard.noHardLimit') %>
                    <% } %>
                </span>
            </div>
        </div>
    </div>
</section>

<div class="stats-grid">
    <div class="stat-card stat-users">
        <div class="stat-header">
            <span class="stat-icon"><i class="ti ti-users"></i></span>
            <span class="stat-trend"><%= t('dashboard.activeUsers') %></span>
        </div>
        <div class="stat-value"><%= stats.users.enabled %></div>
        <div class="stat-label"><%= t('common.of') %> <%= stats.users.total %> <%= t('nav.users').toLowerCase() %></div>
    </div>
    
    <div class="stat-card stat-nodes">
        <div class="stat-header">
            <span class="stat-icon"><i class="ti ti-server"></i></span>
            <span class="stat-trend"><%= t('dashboard.onlineNodes') %></span>
        </div>
        <div class="stat-value"><%= stats.nodes.online %></div>
        <div class="stat-label"><%= t('common.of') %> <%= stats.nodes.total %> <%= t('nav.nodes').toLowerCase() %></div>
    </div>
    
    <div class="stat-card stat-online">
        <div class="stat-header">
            <span class="stat-icon"><i class="ti ti-world"></i></span>
            <span class="stat-trend"><%= t('common.now') %></span>
        </div>
        <div class="stat-value" id="onlineCount"><%= stats.onlineUsers %></div>
        <div class="stat-label"><%= t('common.connections') %></div>
    </div>
    
    <div class="stat-card stat-traffic">
        <div class="stat-header">
            <span class="stat-icon"><i class="ti ti-chart-bar"></i></span>
            <span class="stat-trend"><%= t('dashboard.total') %></span>
        </div>
        <div class="stat-value"><%= formatTrafficDashboard(totalTrafficGB) %></div>
        <div class="stat-label" title="<%= t('common.upload') || 'Upload' %> <%= formatTrafficDashboard(totalTxGB) %> / <%= t('common.download') || 'Download' %> <%= formatTrafficDashboard(totalRxGB) %>">
            <i class="ti ti-arrow-up" style="color:var(--brand-java-dark)"></i> <%= formatTrafficDashboard(totalTxGB) %> / <i class="ti ti-arrow-down" style="color:var(--brand-java-light)"></i> <%= formatTrafficDashboard(totalRxGB) %>
        </div>
    </div>
</div>

<div class="dashboard-grid">
    <div class="dashboard-main">
        <!-- Nodes Status -->
        <div class="card">
    <div class="card-header">
        <h2><i class="ti ti-server"></i> <%= t('dashboard.nodesStatus') %></h2>
                <div class="header-actions">
                    <button class="btn btn-sm" onclick="refreshStats()" title="<%= t('common.refresh') %>"><i class="ti ti-refresh"></i></button>
                </div>
    </div>
            <div class="card-body no-padding">
                <!-- Desktop Table -->
                <div class="table-wrapper">
                <table class="table nodes-table">
            <thead>
                <tr>
                            <th><%= t('dashboard.node') %></th>
                    <th><%= t('common.status') %></th>
                    <th><%= t('common.online') %></th>
                            <th><%= t('dashboard.load') %></th>
                            <th><%= t('dashboard.speed') %></th>
                            <th><%= t('common.actions') %></th>
                </tr>
            </thead>
            <tbody>
                <% if (nodes.length === 0) { %>
                <tr>
                            <td colspan="6" class="text-center text-muted">
                                <a href="/panel/nodes/add" class="btn btn-primary btn-sm mt-2"><%= t('dashboard.addNode') %></a>
                            </td>
                </tr>
                <% } %>
                <% nodes.forEach(function(node, idx) { const displayStatus = node.displayStatus || node.status; %>
                        <tr class="node-row<%= idx >= 20 ? ' node-collapsed' : '' %>" data-nodeid="<%= node._id %>">
                            <td>
                                <div class="node-cell">
                                    <span class="node-name-row">
                                        <% if (node.flag) { %><span class="node-flag"><%= node.flag %></span><% } %>
                                        <strong><%= node.name %></strong>
                                        <img src="/img/<%= node.type === 'xray' ? 'xray' : 'hysteria' %>.svg"
                                             alt="<%= node.type === 'xray' ? 'Xray' : 'Hysteria' %>"
                                             style="width:14px;height:14px;vertical-align:middle;opacity:0.7;">
                                    </span>
                                    <code class="node-ip"><%= node.ip %></code>
                                </div>
                            </td>
                    <td>
                                <span class="status-indicator status-<%= displayStatus %>">
                                    <span class="status-dot"></span>
                            <%= displayStatus %>
                        </span>
                    </td>
                            <td class="online-count"><%= node.onlineUsers || 0 %><% if (node.maxOnlineUsers) { %><span class="online-limit">/<%= node.maxOnlineUsers %></span><% } %></td>
                            <td class="node-load" data-nodeid="<%= node._id %>">
                                <span class="load-placeholder">—</span>
                            </td>
                            <td class="node-speed" data-nodeid="<%= node._id %>">
                                <span class="load-placeholder">—</span>
                            </td>
                            <td>
                                <div class="node-actions">
                                    <button class="btn-icon" onclick="restartNode('<%= node._id %>')" title="<%= t('nodes.restart') %>"><i class="ti ti-refresh"></i></button>
                                    <a href="/panel/nodes/<%= node._id %>" class="btn-icon" title="<%= t('common.settings') %>"><i class="ti ti-settings"></i></a>
                                    <a href="/panel/nodes/<%= node._id %>/terminal" class="btn-icon" title="<%= t('nodes.terminal') %>"><i class="ti ti-terminal-2"></i></a>
                                </div>
                            </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
                </div>
                <% if (nodes.length > 20) { %>
                <div id="showAllNodesWrapper" style="text-align:center;padding:10px 0 6px;">
                    <button class="btn btn-sm" id="showAllNodesBtn" onclick="showAllDashboardNodes()">
                        <i class="ti ti-chevrons-down"></i> <%= t('dashboard.showAll') %> (<%= nodes.length %>)
                    </button>
                </div>
                <% } %>
                
                <!-- Mobile Cards -->
                <div class="mobile-nodes-list">
                    <% if (nodes.length === 0) { %>
                        <div style="text-align: center; padding: 40px 20px;">
                            <p style="color: var(--text-muted); margin-bottom: 16px;"><%= t('dashboard.noNodes') %></p>
                            <a href="/panel/nodes/add" class="btn btn-primary btn-sm"><%= t('dashboard.addNode') %></a>
                        </div>
                    <% } %>
                    <% nodes.forEach(function(node, idx) { const displayStatus = node.displayStatus || node.status; %>
                        <div class="mobile-node-card<%= idx >= 20 ? ' node-collapsed' : '' %>" data-nodeid="<%= node._id %>">
                        <div class="mobile-node-header">
                            <div class="mobile-node-title">
                                <span class="node-name-row">
                                    <% if (node.flag) { %><span class="node-flag"><%= node.flag %></span><% } %>
                                    <strong><%= node.name %></strong>
                                    <img src="/img/<%= node.type === 'xray' ? 'xray' : 'hysteria' %>.svg"
                                         alt="<%= node.type === 'xray' ? 'Xray' : 'Hysteria' %>"
                                         style="width:13px;height:13px;vertical-align:middle;opacity:0.7;">
                                </span>
                                <code><%= node.ip %></code>
                            </div>
                                <span class="status-indicator status-<%= displayStatus %>">
                                    <span class="status-dot"></span>
                                </span>
                            </div>
                            
                            <div class="mobile-node-stats">
                                <div class="mobile-stat-item">
                                    <span class="mobile-stat-label"><%= t('common.online') %></span>
                                    <span class="mobile-stat-value online-count"><%= node.onlineUsers || 0 %><% if (node.maxOnlineUsers) { %><span class="online-limit">/<%= node.maxOnlineUsers %></span><% } %></span>
                                </div>
                                <div class="mobile-stat-item">
                                    <span class="mobile-stat-label"><%= t('common.status') %></span>
                                    <span class="mobile-stat-value"><%= displayStatus %></span>
                                </div>
                                <div class="mobile-stat-item node-load-mobile" data-nodeid="<%= node._id %>">
                                    <span class="mobile-stat-label"><%= t('dashboard.load') %></span>
                                    <span class="mobile-stat-value load-placeholder">—</span>
                                </div>
                                <div class="mobile-stat-item node-speed-mobile" data-nodeid="<%= node._id %>">
                                    <span class="mobile-stat-label"><%= t('dashboard.speed') %></span>
                                    <span class="mobile-stat-value load-placeholder">—</span>
                                </div>
                            </div>
                            
                            <div class="mobile-node-actions">
                                <button class="btn btn-sm" onclick="restartNode('<%= node._id %>')" style="flex: 1;"><i class="ti ti-refresh"></i> Restart</button>
                                <a href="/panel/nodes/<%= node._id %>" class="btn btn-sm" style="flex: 1;"><i class="ti ti-settings"></i> <%= t('common.settings') %></a>
                                <a href="/panel/nodes/<%= node._id %>/terminal" class="btn-icon"><i class="ti ti-terminal-2"></i></a>
                            </div>
                        </div>
                    <% }); %>
                    <% if (nodes.length > 20) { %>
                    <div id="showAllNodesMobileWrapper" style="text-align:center;padding:10px 0 6px;">
                        <button class="btn btn-sm" onclick="showAllDashboardNodes()">
                            <i class="ti ti-chevrons-down"></i> <%= t('dashboard.showAll') %> (<%= nodes.length %>)
                        </button>
                    </div>
                    <% } %>
                </div>
    </div>
</div>

        <!-- Logs -->
        <div class="card mt-2 logs-card">
            <div class="card-header">
                <h2>
                    <span class="logs-status-dot" id="logsStatusDot"></span>
                    <i class="ti ti-file-text"></i> <%= t('dashboard.recentLogs') %>
                </h2>
                <div class="logs-controls">
                    <div class="logs-search-wrap" id="logsSearchWrap">
                        <input type="text" class="logs-search-input" id="logsSearch" placeholder="<%= t('common.search') %>..." oninput="onLogsSearchInput(this.value)">
                        <span class="logs-search-count" id="logsSearchCount"></span>
                        <button class="logs-search-clear" id="logsSearchClear" onclick="clearLogsSearch()" title="<%= t('common.clear') %>"><i class="ti ti-x"></i></button>
                    </div>
                    <button class="btn btn-sm" id="logsToggleBtn" onclick="toggleLogs()" title="<%= t('dashboard.pauseLogs') %>"><i class="ti ti-player-pause"></i></button>
                    <button class="btn btn-sm" onclick="clearLogs()" title="<%= t('common.clear') %>"><i class="ti ti-trash"></i></button>
                </div>
            </div>
            <div class="card-body no-padding">
                <div class="logs-container" id="logsContainer">
                    <div class="logs-loading"><%= t('common.loading') %></div>
                </div>
            </div>
        </div>
    </div>

    <div class="dashboard-sidebar">
        <!-- Quick Actions -->
        <div class="card">
            <div class="card-header">
                <h2><i class="ti ti-bolt"></i> <%= t('dashboard.quickActions') %></h2>
            </div>
            <div class="card-body">
                <div class="quick-actions">
                    <a href="/panel/nodes/add" class="quick-action">
                        <span class="qa-icon"><i class="ti ti-server-2"></i></span>
                        <span class="qa-text"><%= t('dashboard.addNode') %></span>
                    </a>
                    <a href="/panel/users/add" class="quick-action">
                        <span class="qa-icon"><i class="ti ti-user-plus"></i></span>
                        <span class="qa-text"><%= t('dashboard.addUser') %></span>
                    </a>
                    <a href="/panel/stats" class="quick-action">
                        <span class="qa-icon"><i class="ti ti-chart-bar"></i></span>
                        <span class="qa-text"><%= t('nav.stats') %></span>
                    </a>
                    <button class="quick-action" onclick="createBackup()">
                        <span class="qa-icon"><i class="ti ti-device-floppy"></i></span>
                        <span class="qa-text"><%= t('dashboard.backupDb') %></span>
                    </button>
                    <button class="quick-action" onclick="document.getElementById('restoreInput').click()">
                        <span class="qa-icon"><i class="ti ti-download"></i></span>
                        <span class="qa-text"><%= t('dashboard.restoreDb') %></span>
                    </button>
                    <input type="file" id="restoreInput" accept=".tar.gz,.tgz" style="display:none" onchange="restoreBackup(this)">
                </div>
            </div>
        </div>

        <!-- System Info -->
        <div class="card mt-2">
            <div class="card-header">
                <h2><i class="ti ti-device-desktop"></i> <%= t('dashboard.panel') %></h2>
                <button class="btn btn-sm" onclick="loadSystemStats()" title="<%= t('common.refresh') %>"><i class="ti ti-refresh"></i></button>
            </div>
            <div class="card-body">
                <div class="system-info" id="systemStats">
                    <div class="sys-item">
                        <span class="sys-label">CPU</span>
                        <div class="progress-bar-wrap">
                            <div class="progress-bar" id="cpuBar" style="width: 0%"></div>
                        </div>
                        <span class="sys-value" id="cpuValue">—</span>
                    </div>
                    <div class="sys-item">
                        <span class="sys-label">RAM</span>
                        <div class="progress-bar-wrap">
                            <div class="progress-bar" id="ramBar" style="width: 0%"></div>
                        </div>
                        <span class="sys-value" id="ramValue">—</span>
                    </div>
                    <div class="sys-item">
                        <span class="sys-label">RPS</span>
                        <span class="sys-value" id="rpsValue">—</span>
                    </div>
                    <div class="sys-item">
                        <span class="sys-label">Connections</span>
                        <span class="sys-value" id="connectionsValue">—</span>
                    </div>
                    <div class="sys-item">
                        <span class="sys-label">Redis Keys</span>
                        <span class="sys-value" id="cacheValue">—</span>
                    </div>
                    <div class="sys-item">
                        <span class="sys-label">Process</span>
                        <span class="sys-value" id="processValue">—</span>
                    </div>
                    <div class="sys-item">
                        <span class="sys-label">Uptime</span>
                        <span class="sys-value" id="uptime">—</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="toast" class="toast"></div>

<style>
/* Hidden overflow rows -- revealed by showAllDashboardNodes() */
.node-collapsed { display: none !important; }

/* Real-time logs status indicator */
.logs-status-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: 8px;
    background: var(--text-muted);
}
.logs-status-dot.connecting {
    background: var(--warning);
    animation: pulse 1s infinite;
}
.logs-status-dot.connected {
    background: var(--success);
    box-shadow: 0 0 8px var(--success);
}
.logs-status-dot.disconnected,
.logs-status-dot.error {
    background: var(--danger);
}
.logs-controls {
    display: flex;
    gap: 8px;
    align-items: center;
}
.logs-hit {
    background: rgba(99, 102, 241, 0.25);
    color: inherit;
    border-radius: 3px;
    padding: 1px 3px;
    margin: 0 1px;
}
@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}
@keyframes spin {
    to { transform: rotate(360deg); }
}

.progress-bar-wrap {
    width: 60px;
    height: 6px;
    background: var(--border);
    border-radius: 3px;
    margin: 4px 0;
}
.progress-bar {
    height: 100%;
    background: var(--primary);
    border-radius: 3px;
    transition: width 0.3s;
}
.progress-bar.high { background: #ef4444; }
.progress-bar.medium { background: #f59e0b; }
.node-load {
    font-size: 0.8rem;
    color: var(--muted);
}
.node-load .cpu, .node-load .mem {
    display: block;
}
.node-speed {
    font-size: 0.8rem;
    color: var(--muted);
}
.node-speed .speed-up, .node-speed .speed-down {
    display: flex;
    align-items: center;
    gap: 4px;
}
.node-speed .speed-up {
    color: var(--brand-java-dark);
}
.node-speed .speed-down {
    color: var(--brand-java-light);
}
.load-placeholder {
    color: var(--muted);
}
.online-limit {
    color: var(--text-muted);
    font-size: 0.85em;
}
</style>

<script>
const i18n = {
    noLogs: <%- JSON.stringify(t("dashboard.noLogs")) %>,
    loading: <%- JSON.stringify(t("common.loading")) %>,
    loadError: <%- JSON.stringify(t("dashboard.loadError")) %>,
    error: <%- JSON.stringify(t("common.error")) %>,
    nodeRestarted: <%- JSON.stringify(t("dashboard.nodeRestarted")) %>,
    restartError: <%- JSON.stringify(t("dashboard.restartError")) %>,
    creatingBackup: <%- JSON.stringify(t("dashboard.creatingBackup")) %>,
    backupDownloaded: <%- JSON.stringify(t("dashboard.backupDownloaded")) %>,
    backupError: <%- JSON.stringify(t("dashboard.backupError")) %>,
    restoringDb: <%- JSON.stringify(t("dashboard.restoringDb")) %>,
    dbRestored: <%- JSON.stringify(t("dashboard.dbRestored")) %>,
    restoreConfirm: <%- JSON.stringify(t("dashboard.restoreConfirm")) %>
};

// Logs WebSocket
let logsWs = null;
let logsPaused = false;
let logsAutoScroll = true;
let logsSearchDebounce = null;
let logsSearchMode = false;
let logsSearchRequestId = 0;

// Load on page load
document.addEventListener('DOMContentLoaded', () => {
    initTrafficSparkline();
    syncDashboardLogsHeight();
    connectLogsWebSocket();
    loadSystemStats();
    loadNodesStats();
    loadNodesSpeed();
});

function syncDashboardLogsHeight() {
    const sidebar = document.querySelector('.dashboard-sidebar');
    const logsCard = document.querySelector('.logs-card');
    const logsContainer = document.getElementById('logsContainer');
    if (!sidebar || !logsCard || !logsContainer) return;

    const sidebarRect = sidebar.getBoundingClientRect();
    const logsRect = logsContainer.getBoundingClientRect();
    const available = Math.floor(sidebarRect.bottom - logsRect.top - 2);
    if (!Number.isFinite(available) || available < 260) return;

    const capped = Math.max(360, Math.min(available, 640));
    logsContainer.style.height = `${capped}px`;
}

function initTrafficSparkline() {
    const chart = document.querySelector('[data-sparkline-chart]');
    if (!chart) return;

    const svg = chart.querySelector('.sparkline-svg');
    const line = chart.querySelector('.sparkline-line');
    const area = chart.querySelector('.sparkline-area');
    const pointsGroup = chart.querySelector('.sparkline-points');
    const focus = chart.querySelector('.sparkline-focus');
    const focusLine = chart.querySelector('.sparkline-focus-line');
    const focusDot = chart.querySelector('.sparkline-focus-dot');
    const tooltip = chart.querySelector('.sparkline-tooltip');
    const tooltipLabel = chart.querySelector('.sparkline-tooltip-label');
    const tooltipValue = chart.querySelector('.sparkline-tooltip-value');
    const title = document.querySelector('[data-sparkline-title]');
    const totalNode = chart.parentElement?.querySelector('.sparkline-copy strong');
    const footerNodes = chart.parentElement?.querySelectorAll('.sparkline-foot span');
    const periodButtons = Array.from(document.querySelectorAll('[data-sparkline-period]'));
    const width = 320;
    const height = 152;
    const paddingX = 10;
    const paddingTop = 26;
    const paddingBottom = 22;
    const usableWidth = width - paddingX * 2;
    const usableHeight = height - paddingTop - paddingBottom;
    let points = [];

    const formatTrafficWindowValue = (bytes) => {
        const kb = bytes / 1024;
        const mb = bytes / (1024 * 1024);
        const gb = bytes / (1024 * 1024 * 1024);
        if (gb >= 1) return gb.toFixed(2) + ' GB';
        if (mb >= 1) return mb.toFixed(1) + ' MB';
        if (kb >= 1) return kb.toFixed(0) + ' KB';
        return Math.max(bytes, 0).toFixed(0) + ' B';
    };

    const formatTrafficDashboard = (bytes) => {
        const gb = bytes / (1024 * 1024 * 1024);
        if (gb >= 1000) return (gb / 1024).toFixed(2) + ' TB';
        if (gb >= 1) return gb.toFixed(1) + ' GB';
        const mb = bytes / (1024 * 1024);
        if (mb >= 1) return mb.toFixed(0) + ' MB';
        return formatTrafficWindowValue(bytes);
    };

    const dashboardLocale = <%- JSON.stringify(lang === 'ru' ? 'ru-RU' : 'en-US') %>;
    const trafficPeriodLabels = {
        '24h': <%- JSON.stringify(t('dashboard.traffic24h')) %>,
        '7d': <%- JSON.stringify(t('dashboard.traffic7d')) %>,
        '30d': <%- JSON.stringify(t('dashboard.traffic30d')) %>
    };

    const formatTrafficPeriodLabel = (period) => trafficPeriodLabels[period] || <%- JSON.stringify(t('dashboard.traffic7d')) %>;

    const formatPointLabel = (rawLabel, period) => {
        const value = new Date(rawLabel);
        if (Number.isNaN(value.getTime())) return rawLabel || '—';
        if (period === '24h') {
            return value.toLocaleTimeString(dashboardLocale, { hour: '2-digit', minute: '2-digit' });
        }
        if (period === '30d') {
            return value.toLocaleDateString(dashboardLocale, { day: '2-digit', month: 'short' });
        }
        return value.toLocaleDateString(dashboardLocale, { day: '2-digit', month: 'short' });
    };

    const getSmoothPath = (dataset) => dataset.map((point, index) => {
        if (index === 0) return `M ${point.x} ${point.y}`;
        const prev = dataset[index - 1];
        const controlX = (prev.x + point.x) / 2;
        return `C ${controlX} ${prev.y}, ${controlX} ${point.y}, ${point.x} ${point.y}`;
    }).join(' ');

    const showPoint = (index) => {
        const point = points[index];
        if (!point) return;
        focus.hidden = false;
        tooltip.hidden = false;
        focusLine.setAttribute('x1', point.x);
        focusLine.setAttribute('x2', point.x);
        focusDot.setAttribute('cx', point.x);
        focusDot.setAttribute('cy', point.y);
        tooltipLabel.textContent = point.label;
        tooltipValue.textContent = point.display || '0 B';

        const left = (point.x / width) * chart.clientWidth;
        tooltip.style.left = `${left}px`;
        tooltip.style.top = `${Math.max(point.y - 10, 44)}px`;

        pointsGroup.querySelectorAll('.sparkline-point').forEach((node, pointIndex) => {
            node.classList.toggle('is-active', Number(node.dataset.index) === index);
        });
    };

    const hidePoint = () => {
        focus.hidden = true;
        tooltip.hidden = true;
        pointsGroup.querySelectorAll('.sparkline-point').forEach((node) => {
            node.classList.remove('is-active');
        });
    };

    chart.addEventListener('mousemove', (event) => {
        if (!points.length) return;
        const rect = chart.getBoundingClientRect();
        const relativeX = ((event.clientX - rect.left) / rect.width) * width;
        let nearestIndex = 0;
        let nearestDistance = Infinity;

        points.forEach((point, index) => {
            const distance = Math.abs(point.x - relativeX);
            if (distance < nearestDistance) {
                nearestDistance = distance;
                nearestIndex = index;
            }
        });

        showPoint(nearestIndex);
    });

    chart.addEventListener('mouseleave', hidePoint);
    chart.addEventListener('touchstart', () => points.length && showPoint(points.length - 1), { passive: true });
    chart.addEventListener('touchend', hidePoint, { passive: true });

    const renderChart = (rawPoints, period) => {
        if (!Array.isArray(rawPoints) || rawPoints.length < 2) return;

        const values = rawPoints.map((point) => Number(point.raw || 0));
        const maxValue = Math.max(...values, 1);
        const minValue = Math.min(...values, 0);
        const valueRange = Math.max(maxValue - minValue, Math.max(maxValue, 1) * 0.18, 1);
        const upperBound = maxValue + valueRange * 0.18;
        const lowerBound = Math.max(0, minValue - valueRange * 0.12);
        const normalizedRange = Math.max(upperBound - lowerBound, 1);

        points = rawPoints.map((point, index) => {
            const x = paddingX + (usableWidth / (rawPoints.length - 1)) * index;
            const y = paddingTop + usableHeight - (((Number(point.raw || 0) - lowerBound) / normalizedRange) * usableHeight);
            return { ...point, x, y };
        });

        const linePath = getSmoothPath(points);
        const areaPath = `${linePath} L ${points[points.length - 1].x} ${height - 4} L ${points[0].x} ${height - 4} Z`;
        line.setAttribute('d', linePath);
        area.setAttribute('d', areaPath);

        const desiredMarkers = Math.max(4, Math.floor((chart.clientWidth || 320) / 96));
        const step = Math.max(1, Math.ceil(points.length / desiredMarkers));
        pointsGroup.innerHTML = points
            .filter((point, index) => index === 0 || index === points.length - 1 || index % step === 0)
            .map((point, index) => `<circle class="sparkline-point" data-index="${points.indexOf(point)}" cx="${point.x}" cy="${point.y}" r="3.5"></circle>`)
            .join('');

        if (title) title.textContent = formatTrafficPeriodLabel(period);
        periodButtons.forEach((button) => button.classList.toggle('active', button.dataset.sparklinePeriod === period));
        chart.dataset.period = period;
        const mostRelevantIndex = (() => {
            let maxIndex = points.length - 1;
            let maxValue = -1;
            for (let index = 0; index < rawPoints.length; index += 1) {
                if ((rawPoints[index]?.raw || 0) >= maxValue) {
                    maxValue = rawPoints[index]?.raw || 0;
                    maxIndex = index;
                }
            }
            if (maxValue > 0) return maxIndex;
            return points.length - 1;
        })();
        showPoint(mostRelevantIndex);
    };

    const toPoints = (payload) => (payload?.labels || []).map((label, index) => ({
        label: formatPointLabel(label, payload.period),
        raw: (payload?.datasets?.tx?.[index] || 0) + (payload?.datasets?.rx?.[index] || 0),
        display: formatTrafficWindowValue((payload?.datasets?.tx?.[index] || 0) + (payload?.datasets?.rx?.[index] || 0)),
    }));

    const updateFromPayload = (payload) => {
        const nextPoints = toPoints(payload);
        if (totalNode) totalNode.textContent = formatTrafficDashboard(payload?.totals?.total || 0);
        if (footerNodes?.[0]) footerNodes[0].innerHTML = `<i class="ti ti-arrow-up-right"></i> ${formatTrafficDashboard(payload?.totals?.tx || 0)}`;
        if (footerNodes?.[1]) footerNodes[1].innerHTML = `<i class="ti ti-arrow-down-right"></i> ${formatTrafficDashboard(payload?.totals?.rx || 0)}`;
        renderChart(nextPoints, payload?.period || '7d');
    };

    periodButtons.forEach((button) => {
        button.addEventListener('click', async () => {
            const period = button.dataset.sparklinePeriod;
            try {
                const response = await fetch(`/panel/stats/api/traffic?period=${period}`, { credentials: 'include' });
                if (!response.ok) throw new Error('Failed to load traffic chart');
                const payload = await response.json();
                updateFromPayload(payload);
            } catch (error) {
                console.error(error);
            }
        });
    });

    renderChart(
        (JSON.parse(chart.dataset.points || '[]')).map((point) => ({
            ...point,
            label: formatPointLabel(point.label, chart.dataset.period || '7d'),
        })),
        chart.dataset.period || '7d'
    );

    if ('ResizeObserver' in window) {
        const resizeObserver = new ResizeObserver(() => {
            renderChart(points.length ? points : (JSON.parse(chart.dataset.points || '[]')).map((point) => ({
                ...point,
                label: formatPointLabel(point.label, chart.dataset.period || '7d'),
            })), chart.dataset.period || '7d');
            syncDashboardLogsHeight();
        });
        resizeObserver.observe(chart);
    }
}

function connectLogsWebSocket() {
    const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
    const wsUrl = `${protocol}//${window.location.host}/ws/logs`;
    
    updateLogsStatus('connecting');
    
    logsWs = new WebSocket(wsUrl);
    
    logsWs.onopen = () => {
        updateLogsStatus('connected');
    };
    
    logsWs.onmessage = (event) => {
        if (logsPaused || logsSearchMode) return;
        
        const msg = JSON.parse(event.data);
        
        if (msg.type === 'history') {
            const container = document.getElementById('logsContainer');
            if (msg.logs && msg.logs.length > 0) {
                container.innerHTML = msg.logs.map(log => formatLogLine(log)).join('');
                scrollLogsToBottom();
            } else {
                container.innerHTML = '<div class="logs-empty">' + i18n.noLogs + '</div>';
            }
        } else if (msg.type === 'log') {
            appendLog(msg);
        }
    };
    
    logsWs.onclose = () => {
        updateLogsStatus('disconnected');
        setTimeout(connectLogsWebSocket, 3000);
    };
    
    logsWs.onerror = () => {
        updateLogsStatus('error');
    };
}

function formatLogLine(log) {
    const level = log.level || 'info';
    const message = `${log.timestamp} [${level.toUpperCase()}]: ${log.message}`;
    let cls = 'log-line';
    if (level === 'error') cls += ' log-error';
    else if (level === 'warn') cls += ' log-warn';
    else if (message.includes('✅') || message.includes('✓')) cls += ' log-success';
    return `<div class="${cls}">${escapeHtml(message)}</div>`;
}

function formatRawLine(line, query = '') {
    let cls = 'log-line';
    if (line.includes('"level":"error"') || line.includes('[ERROR]')) cls += ' log-error';
    else if (line.includes('"level":"warn"') || line.includes('[WARN]')) cls += ' log-warn';
    else if (line.includes('✅') || line.includes('✓')) cls += ' log-success';

    const escapedLine = escapeHtml(line);
    if (!query) {
        return `<div class="${cls}">${escapedLine}</div>`;
    }

    const escapedQuery = escapeHtml(query);
    const highlightRegex = new RegExp(`(${escapeRegExp(escapedQuery)})`, 'ig');
    const highlighted = escapedLine.replace(highlightRegex, '<mark class="logs-hit">$1</mark>');

    return `<div class="${cls}">${highlighted}</div>`;
}

function appendLog(log) {
    const container = document.getElementById('logsContainer');
    
    const emptyMsg = container.querySelector('.logs-empty');
    if (emptyMsg) emptyMsg.remove();
    
    const logHtml = formatLogLine(log);
    container.insertAdjacentHTML('afterbegin', logHtml);
    
    const lines = container.querySelectorAll('.log-line');
    if (lines.length > 100) {
        lines[lines.length - 1].remove();
    }
}

function onLogsSearchInput(value) {
    const clearBtn = document.getElementById('logsSearchClear');
    const countEl = document.getElementById('logsSearchCount');
    const hasValue = value.trim().length > 0;
    clearBtn.style.display = hasValue ? 'flex' : 'none';
    if (!hasValue && countEl) countEl.textContent = '';

    clearTimeout(logsSearchDebounce);
    logsSearchDebounce = setTimeout(() => {
        const q = value.trim();
        if (q) {
            execLogsSearch(q);
        } else {
            exitLogsSearchMode();
        }
    }, 400);
}

async function execLogsSearch(q) {
    const requestId = ++logsSearchRequestId;
    logsSearchMode = true;
    const container = document.getElementById('logsContainer');
    const countEl = document.getElementById('logsSearchCount');

    container.innerHTML = '<div class="logs-loading">' + i18n.loading + '</div>';
    if (countEl) countEl.textContent = '...';

    try {
        const res = await fetch(`/panel/logs/search?q=${encodeURIComponent(q)}&limit=200`, { credentials: 'include' });
        const data = await res.json();

        if (!logsSearchMode || requestId !== logsSearchRequestId) return;

        if (data.matches && data.matches.length > 0) {
            container.innerHTML = data.matches.map(line => formatRawLine(line, q)).join('');
            if (countEl) {
                const shown = data.matches.length;
                const total = data.total;
                countEl.textContent = shown < total ? `${shown}/${total}` : `${total}`;
            }
        } else {
            container.innerHTML = '<div class="logs-empty">' + i18n.noLogs + '</div>';
            if (countEl) countEl.textContent = '0';
        }
    } catch (e) {
        if (logsSearchMode) {
            container.innerHTML = '<div class="logs-empty">—</div>';
            if (countEl) countEl.textContent = '';
        }
    }
}

function exitLogsSearchMode() {
    logsSearchMode = false;
    logsSearchRequestId += 1;
    const countEl = document.getElementById('logsSearchCount');
    if (countEl) countEl.textContent = '';
    const container = document.getElementById('logsContainer');
    container.innerHTML = '<div class="logs-loading">' + i18n.loading + '</div>';
    if (logsWs) {
        logsWs.onclose = null;
        logsWs.close();
        logsWs = null;
    }
    connectLogsWebSocket();
}

function clearLogsSearch() {
    const input = document.getElementById('logsSearch');
    input.value = '';
    input.focus();
    onLogsSearchInput('');
}

function setLogsSearchUiState(state) {
    // Оставлен для совместимости, состояние теперь отображается через count badge
}

function scrollLogsToBottom() {
    if (logsAutoScroll) {
        const container = document.getElementById('logsContainer');
        container.scrollTop = 0;
    }
}

function updateLogsStatus(status) {
    const dot = document.getElementById('logsStatusDot');
    dot.className = 'logs-status-dot ' + status;
}

function toggleLogs() {
    logsPaused = !logsPaused;
    const btn = document.getElementById('logsToggleBtn');
    btn.innerHTML = logsPaused ? '<i class="ti ti-player-play"></i>' : '<i class="ti ti-player-pause"></i>';
    btn.title = logsPaused ? 'Resume' : 'Pause';
}

function clearLogs() {
    document.getElementById('logsContainer').innerHTML = '<div class="logs-empty">' + i18n.noLogs + '</div>';
}

function escapeHtml(str) {
    return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

function escapeRegExp(str) {
    return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

async function loadSystemStats() {
    try {
        const res = await fetch('/panel/system-stats', { credentials: 'include' });
        const data = await res.json();
        
        if (data.success) {
            // CPU в процентах
            const cpuPercent = data.cpu.percent || 0;
            const cpuBar = document.getElementById('cpuBar');
            cpuBar.style.width = cpuPercent + '%';
            cpuBar.className = 'progress-bar' + (cpuPercent > 80 ? ' high' : cpuPercent > 60 ? ' medium' : '');
            document.getElementById('cpuValue').textContent = cpuPercent + '%';
            
            // RAM
            const ramPercent = data.mem.percent;
            const ramBar = document.getElementById('ramBar');
            ramBar.style.width = ramPercent + '%';
            ramBar.className = 'progress-bar' + (ramPercent > 80 ? ' high' : ramPercent > 60 ? ' medium' : '');
            document.getElementById('ramValue').textContent = ramPercent + '%';
            
            // RPS (Requests Per Second)
            const rps = data.requests?.rps || 0;
            const rpm = data.requests?.rpm || 0;
            document.getElementById('rpsValue').textContent = `${rps}/s (${rpm}/m)`;
            
            // Active connections
            document.getElementById('connectionsValue').textContent = data.connections || 0;
            
            // Cache (Redis keys)
            const cacheKeys = data.cache?.keys || 0;
            const cacheMem = data.cache?.usedMemoryMB || '0';
            document.getElementById('cacheValue').textContent = `${cacheKeys} (${cacheMem}MB)`;
            
            // Process memory
            const processMB = Math.round(data.process.rss / 1024 / 1024);
            document.getElementById('processValue').textContent = processMB + ' MB';
            
            // Uptime
            const uptime = data.uptime;
            const hours = Math.floor(uptime / 3600);
            const mins = Math.floor((uptime % 3600) / 60);
            document.getElementById('uptime').textContent = `${hours}h ${mins}m`;
        }
        syncDashboardLogsHeight();
    } catch (e) {
        console.error('Failed to load system stats:', e);
    }
}

window.addEventListener('load', syncDashboardLogsHeight);
window.addEventListener('pageshow', syncDashboardLogsHeight);
window.addEventListener('resize', syncDashboardLogsHeight);

async function loadNodesStats(onlyIds) {
    const renderStats = (data, desktopEl, mobileEl) => {
        if (data.success) {
            const cpuPercent = Math.min(Math.round((data.cpu.load1 / data.cpu.cores) * 100), 100);
            const memPercent = data.mem.percent;
            
            let cpuColor = 'var(--text-primary)';
            if (cpuPercent >= 80) cpuColor = '#ef4444';
            else if (cpuPercent >= 60) cpuColor = '#f59e0b';
            
            if (desktopEl) {
                desktopEl.innerHTML = `
                    <span class="cpu" style="color: ${cpuColor}">CPU: ${cpuPercent}%</span>
                    <span class="mem">RAM: ${memPercent}%</span>
                `;
            }
            if (mobileEl) {
                mobileEl.innerHTML = `<span style="color: ${cpuColor}">${cpuPercent}%</span> / ${memPercent}%`;
            }
        } else {
            if (desktopEl) desktopEl.innerHTML = '<span class="load-placeholder">N/A</span>';
            if (mobileEl) mobileEl.textContent = 'N/A';
        }
    };
    
    // Collect visible node IDs only -- skip collapsed rows to avoid N*2 requests on page load
    // When onlyIds is provided, further restrict to that set (used by showAllDashboardNodes)
    const nodesMap = new Map();
    
    document.querySelectorAll('.node-row:not(.node-collapsed)').forEach(row => {
        const nodeId = row.dataset.nodeid;
        if (onlyIds && !onlyIds.has(nodeId)) return;
        if (!nodesMap.has(nodeId)) nodesMap.set(nodeId, { desktop: null, mobile: null });
        nodesMap.get(nodeId).desktop = row.querySelector('.node-load');
    });
    
    document.querySelectorAll('.node-load-mobile').forEach(card => {
        const row = card.closest('.mobile-node-card');
        if (row && row.classList.contains('node-collapsed')) return;
        const nodeId = card.dataset.nodeid;
        if (onlyIds && !onlyIds.has(nodeId)) return;
        if (!nodesMap.has(nodeId)) nodesMap.set(nodeId, { desktop: null, mobile: null });
        nodesMap.get(nodeId).mobile = card.querySelector('.mobile-stat-value');
    });
    
    // One request per visible node, in parallel
    const tasks = Array.from(nodesMap.entries()).map(([nodeId, elements]) => 
        fetch(`/panel/nodes/${nodeId}/stats`, { credentials: 'include' })
            .then(res => res.json())
            .then(data => renderStats(data, elements.desktop, elements.mobile))
            .catch(() => {
                if (elements.desktop) elements.desktop.innerHTML = '<span class="load-placeholder">—</span>';
                if (elements.mobile) elements.mobile.textContent = '—';
            })
    );
    
    await Promise.all(tasks);
}

async function loadNodesSpeed(onlyIds) {
    const formatSpeed = (bytes) => {
        const bits = bytes * 8;
        if (bits < 1000) return `${bits.toFixed(0)} bit/s`;
        if (bits < 1000 * 1000) return `${(bits / 1000).toFixed(1)} Kbit/s`;
        if (bits < 1000 * 1000 * 1000) return `${(bits / 1000 / 1000).toFixed(1)} Mbit/s`;
        return `${(bits / 1000 / 1000 / 1000).toFixed(2)} Gbit/s`;
    };
    
    const renderSpeed = (data, desktopEl, mobileEl) => {
        if (data.success) {
            const txSpeed = formatSpeed(data.tx);
            const rxSpeed = formatSpeed(data.rx);
            
            if (desktopEl) {
                desktopEl.innerHTML = `
                    <span class="speed-up" title="Upload"><i class="ti ti-arrow-up"></i> ${txSpeed}</span>
                    <span class="speed-down" title="Download"><i class="ti ti-arrow-down"></i> ${rxSpeed}</span>
                `;
            }
            if (mobileEl) {
                mobileEl.innerHTML = `
                    <span style="color: var(--brand-java-dark); font-size: 12px;"><i class="ti ti-arrow-up"></i> ${txSpeed}</span><br>
                    <span style="color: var(--brand-java-light); font-size: 12px;"><i class="ti ti-arrow-down"></i> ${rxSpeed}</span>
                `;
            }
        } else {
            if (desktopEl) desktopEl.innerHTML = '<span class="load-placeholder">N/A</span>';
            if (mobileEl) mobileEl.textContent = 'N/A';
        }
    };
    
    // Collect visible node IDs only -- skip collapsed rows
    // When onlyIds is provided, further restrict to that set (used by showAllDashboardNodes)
    const nodesMap = new Map();
    
    document.querySelectorAll('.node-row:not(.node-collapsed)').forEach(row => {
        const nodeId = row.dataset.nodeid;
        if (onlyIds && !onlyIds.has(nodeId)) return;
        if (!nodesMap.has(nodeId)) nodesMap.set(nodeId, { desktop: null, mobile: null });
        const el = row.querySelector('.node-speed');
        el.innerHTML = '<span class="load-placeholder"><i class="ti ti-loader-2"></i></span>';
        nodesMap.get(nodeId).desktop = el;
    });
    
    document.querySelectorAll('.node-speed-mobile').forEach(card => {
        const row = card.closest('.mobile-node-card');
        if (row && row.classList.contains('node-collapsed')) return;
        const nodeId = card.dataset.nodeid;
        if (onlyIds && !onlyIds.has(nodeId)) return;
        if (!nodesMap.has(nodeId)) nodesMap.set(nodeId, { desktop: null, mobile: null });
        const el = card.querySelector('.mobile-stat-value');
        el.innerHTML = '<i class="ti ti-loader-2"></i>';
        nodesMap.get(nodeId).mobile = el;
    });
    
    // One request per visible node, in parallel
    const tasks = Array.from(nodesMap.entries()).map(([nodeId, elements]) => 
        fetch(`/panel/nodes/${nodeId}/speed`, { credentials: 'include' })
            .then(res => res.json())
            .then(data => renderSpeed(data, elements.desktop, elements.mobile))
            .catch(() => {
                if (elements.desktop) elements.desktop.innerHTML = '<span class="load-placeholder">—</span>';
                if (elements.mobile) elements.mobile.textContent = '—';
            })
    );
    
    await Promise.all(tasks);
}

// Expand all hidden nodes and load their stats/speed (only for newly revealed)
async function showAllDashboardNodes() {
    // Collect IDs of nodes that were collapsed (not yet loaded)
    const newIds = new Set();
    document.querySelectorAll('.node-collapsed').forEach(el => {
        newIds.add(el.dataset.nodeid);
        el.classList.remove('node-collapsed');
    });
    const wrapper = document.getElementById('showAllNodesWrapper');
    if (wrapper) wrapper.remove();
    const mobileWrapper = document.getElementById('showAllNodesMobileWrapper');
    if (mobileWrapper) mobileWrapper.remove();
    if (newIds.size === 0) return;
    // Only fetch stats/speed for newly revealed nodes
    await Promise.all([loadNodesStats(newIds), loadNodesSpeed(newIds)]);
}

async function refreshStats() {
    location.reload();
}

async function restartNode(nodeId) {
    const row = document.querySelector(`tr[data-nodeid="${nodeId}"]`);
    const btn = row.querySelector('.btn-icon');
    btn.disabled = true;
    btn.innerHTML = '<i class="ti ti-loader-2"></i>';
    
    try {
        const res = await fetch(`/panel/nodes/${nodeId}/restart`, { 
            method: 'POST', 
            credentials: 'include' 
        });
        const data = await res.json();
        
        if (data.success) {
            showToast(i18n.nodeRestarted);
            row.querySelector('.status-indicator').className = 'status-indicator status-online';
            row.querySelector('.status-indicator').innerHTML = '<span class="status-dot"></span>online';
        } else {
            showToast(i18n.error + ': ' + (data.error || 'unknown'), 'error');
        }
    } catch (e) {
        showToast(i18n.restartError, 'error');
    }
    
    btn.disabled = false;
    btn.innerHTML = '<i class="ti ti-refresh"></i>';
}

async function createBackup() {
    showToast(i18n.creatingBackup);
    try {
        const res = await fetch('/panel/backup', { 
            method: 'POST', 
            credentials: 'include' 
        });
        
        if (!res.ok) {
            const data = await res.json();
            showToast(i18n.error + ': ' + (data.error || 'unknown'), 'error');
            return;
        }
        
        const blob = await res.blob();
        const contentDisposition = res.headers.get('Content-Disposition');
        let filename = 'backup.tar.gz';
        if (contentDisposition) {
            const match = contentDisposition.match(/filename="?([^";\n]+)"?/);
            if (match) filename = match[1];
        }
        
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        window.URL.revokeObjectURL(url);
        
        showToast(i18n.backupDownloaded);
    } catch (e) {
        showToast(i18n.backupError, 'error');
    }
}

async function restoreBackup(input) {
    const file = input.files[0];
    if (!file) return;
    
    const confirmMsg = i18n.restoreConfirm.replace('{filename}', file.name);
    if (!confirm(confirmMsg)) {
        input.value = '';
        return;
    }
    
    showToast(i18n.restoringDb);
    
    const formData = new FormData();
    formData.append('backup', file);
    
    try {
        const res = await fetch('/panel/restore', { 
            method: 'POST', 
            credentials: 'include',
            body: formData
        });
        const data = await res.json();
        
        if (data.success) {
            showToast(i18n.dbRestored);
            setTimeout(() => location.reload(), 1500);
        } else {
            showToast(i18n.error + ': ' + (data.error || 'unknown'), 'error');
        }
    } catch (e) {
        showToast(i18n.error + ' restore', 'error');
    }
    
    input.value = '';
}

</script>
