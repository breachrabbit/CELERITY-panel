<style>
.proto-switcher {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 8px;
}
.proto-option {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 16px;
    border: 2px solid var(--border);
    border-radius: var(--radius);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    position: relative;
}
.proto-option input[type="radio"] { position: absolute; opacity: 0; pointer-events: none; }
.proto-option:hover { border-color: var(--accent); background: var(--accent-glow); }
.proto-option.active { border-color: var(--accent); background: var(--accent-glow); }
.proto-icon { font-size: 22px; }
.proto-name { font-weight: 600; font-size: 14px; }
.proto-desc { font-size: 11px; color: var(--text-muted); }
.section-subtitle {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 8px;
}

.code-textarea {
    font-family: 'JetBrains Mono', 'Consolas', 'Monaco', monospace;
    font-size: 13px;
    background: var(--bg-primary);
    color: var(--text-primary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 15px;
    width: 100%;
    resize: vertical;
    line-height: 1.5;
}
.code-textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-glow);
}

.code-block-wrap {
    position: relative;
    margin-top: 10px;
}
.code-block {
    margin: 0;
    padding: 14px;
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: 'JetBrains Mono', 'Consolas', 'Monaco', monospace;
    font-size: 13px;
    line-height: 1.5;
    overflow: auto;
    white-space: pre;
}
.config-copy-btn {
    position: absolute;
    top: 8px;
    right: 8px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 3px 10px;
    font-size: 11px;
    cursor: pointer;
    color: var(--text-muted);
}
.config-copy-btn.is-copied {
    color: var(--success);
    border-color: var(--success);
}
.config-hint {
    margin-bottom: 0;
}
.input-with-button {
    display: flex;
    gap: 8px;
    align-items: center;
}
.input-with-button input { flex: 1; }
.input-with-button .btn { white-space: nowrap; flex-shrink: 0; }

.ssh-warning {
    background: var(--warning-bg);
    border: 1px solid var(--warning);
    border-radius: var(--radius-sm);
    padding: 12px 16px;
    margin-bottom: 16px;
    color: var(--warning);
    display: flex;
    align-items: center;
    gap: 10px;
}
.ssh-warning-icon { font-size: 20px; }

.node-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
}
.node-info-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 10px 14px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
}
.node-info-label {
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}
.node-info-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
}
.logs-output {
    background: #1a1a2e;
    color: #0f0;
    padding: 15px;
    border-radius: 8px;
    font-family: 'Consolas', 'Monaco', monospace;
    font-size: 12px;
    max-height: 500px;
    overflow-y: auto;
    white-space: pre-wrap;
    word-break: break-all;
    margin-top: 10px;
}
.logs-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.logs-output .error { color: #ff6b6b; }
.logs-output .success { color: #51cf66; }
.logs-output .warning { color: #ffd43b; }
.logs-output .stderr { color: #9fb3ff; }

.onboarding-jobs-summary {
    display: grid;
    gap: 10px;
}
.onboarding-job-card {
    border: 1px dashed var(--border);
    border-radius: var(--radius-sm);
    padding: 10px 12px;
    background: var(--bg-secondary);
}
.onboarding-job-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 8px;
}
.onboarding-job-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
}
.onboarding-job-meta {
    font-size: 12px;
    color: var(--text-muted);
    display: grid;
    gap: 4px;
}
.onboarding-job-error {
    margin-top: 8px;
    font-size: 12px;
    color: var(--danger);
}
.onboarding-job-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 10px;
}
.onboarding-job-actions .btn {
    padding: 4px 8px;
    font-size: 11px;
}
.onboarding-job-details {
    margin-top: 8px;
    border-top: 1px dashed var(--border);
    padding-top: 8px;
}
.onboarding-job-details summary {
    cursor: pointer;
    color: var(--text-secondary);
    font-size: 12px;
    font-weight: 600;
    list-style: none;
}
.onboarding-job-details summary::-webkit-details-marker {
    display: none;
}
.onboarding-job-details summary::before {
    content: "▸";
    display: inline-block;
    margin-right: 6px;
    transition: transform 0.15s ease;
}
.onboarding-job-details[open] summary::before {
    transform: rotate(90deg);
}
.onboarding-step-states {
    margin-top: 8px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
}
.onboarding-step-chip {
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 2px 8px;
    font-size: 10px;
    color: var(--text-muted);
    text-transform: uppercase;
}
.onboarding-step-chip.is-completed {
    border-color: rgba(8, 197, 203, 0.4);
    color: var(--accent);
}
.onboarding-step-chip.is-running {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-glow);
}
.onboarding-step-chip.is-failed {
    border-color: rgba(255, 82, 82, 0.35);
    color: var(--danger);
}
.onboarding-step-chip.is-blocked {
    border-color: rgba(255, 176, 32, 0.4);
    color: var(--warning);
}
.onboarding-step-chip.is-pending {
    opacity: 0.75;
}
.onboarding-job-log-preview {
    margin-top: 8px;
    max-height: 180px;
    overflow: auto;
    background: var(--bg-primary);
    border: 1px dashed var(--border);
    border-radius: 8px;
    padding: 8px 10px;
    font-family: 'JetBrains Mono', 'Consolas', 'Monaco', monospace;
    font-size: 11px;
    color: var(--text-secondary);
    white-space: pre-wrap;
    word-break: break-word;
}
.onboarding-job-hint {
    margin-top: 8px;
    font-size: 11px;
    color: var(--warning);
}

@media (max-width: 900px) {
    .onboarding-job-head {
        flex-direction: column;
        align-items: stretch;
    }
}
.form-group.is-inactive {
    opacity: 0.55;
}

@media (max-width: 640px) {
    .form-row-3 { grid-template-columns: 1fr; }
}

.node-advanced-details {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-bottom: 16px;
    background: var(--bg-secondary);
}
.node-advanced-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    cursor: pointer;
    font-weight: 600;
    font-size: 14px;
    color: var(--text-secondary);
    user-select: none;
    list-style: none;
    gap: 8px;
}
.node-advanced-summary::-webkit-details-marker { display: none; }
.node-advanced-summary:hover { color: var(--text-primary); }
.node-advanced-summary span { display: flex; align-items: center; gap: 8px; }
.node-advanced-chevron {
    transition: transform 0.2s;
    font-size: 16px;
    flex-shrink: 0;
}
.node-advanced-details[open] .node-advanced-chevron {
    transform: rotate(180deg);
}
.node-advanced-details > .form-section {
    border-top: 1px solid var(--border);
    border-radius: 0;
    margin-bottom: 0;
    margin-top: 0;
    padding: 20px 20px 16px;
    background: transparent;
}
.node-advanced-details > .form-section:last-of-type {
    border-bottom-left-radius: var(--radius);
    border-bottom-right-radius: var(--radius);
}

/* ── SNI Scanner modal ── */
.sni-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.6);
    z-index: 9000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 40px 16px 16px;
    overflow-y: auto;
}
.sni-modal-card {
    background: var(--bg-card, var(--bg-secondary));
    border: 1px solid var(--border);
    border-radius: var(--radius);
    width: min(820px, 100%);
    display: flex;
    flex-direction: column;
    box-shadow: 0 32px 80px rgba(0,0,0,.6);
    margin: auto;
}
.sni-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 22px 14px;
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
}
.sni-modal-header h3 {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
}
.sni-modal-body {
    padding: 20px 22px 22px;
}
.sni-modal-hint {
    font-size: 12px;
    color: var(--text-muted);
    margin: 0 0 16px;
    line-height: 1.5;
}
/* 2-row params grid */
.sni-params {
    display: grid;
    grid-template-columns: 1fr 100px;
    gap: 12px;
    margin-bottom: 14px;
}
.sni-params-row2 {
    display: grid;
    grid-template-columns: 1fr 1fr 160px;
    gap: 12px;
    margin-bottom: 14px;
}
.sni-scan-controls {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
}
.sni-scan-status {
    font-size: 12px;
    color: var(--text-muted);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
.sni-progress-bar {
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 16px;
}
.sni-progress-fill {
    height: 100%;
    background: var(--accent);
    transition: width .1s linear;
}
.sni-results-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
}
.sni-results-title { font-weight: 600; font-size: 13px; }
.sni-results-count {
    font-size: 12px;
    color: var(--text-muted);
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1px 8px;
}
.sni-table-wrap {
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    max-height: 360px;
    overflow-y: auto;
    overflow-x: hidden;
}
.sni-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    table-layout: fixed;
}
.sni-table th {
    position: sticky;
    top: 0;
    background: var(--bg-secondary);
    padding: 8px 12px;
    text-align: left;
    font-weight: 600;
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: .5px;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
}
.sni-table td {
    padding: 9px 12px;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
.sni-table tr:last-child td { border-bottom: none; }
.sni-table tr:hover td { background: var(--accent-glow); }
/* Column widths */
.sni-table th:nth-child(1), .sni-table td:nth-child(1) { width: 72px; }   /* Ping   */
.sni-table th:nth-child(2), .sni-table td:nth-child(2) { width: auto; }    /* Domain */
.sni-table th:nth-child(3), .sni-table td:nth-child(3) { width: 140px; }  /* IP     */
.sni-table th:nth-child(4), .sni-table td:nth-child(4) { width: 130px; }  /* Issuer */
.sni-table th:nth-child(5), .sni-table td:nth-child(5) { width: 48px; text-align:center; } /* Apply */
.sni-ping-fast  { color: var(--success); font-weight: 600; }
.sni-ping-mid   { color: var(--warning); font-weight: 600; }
.sni-ping-slow  { color: var(--text-muted); }
.sni-domain     { font-weight: 500; }
.sni-issuer     { font-size: 11px; color: var(--text-muted); }
.sni-empty {
    text-align: center;
    color: var(--text-muted);
    font-size: 13px;
    padding: 28px 0;
}
.sni-ip-neighbor {
    font-size: 12px;
    font-family: 'JetBrains Mono', monospace;
    color: var(--success);
}
.sni-ip-other {
    font-size: 12px;
    font-family: 'JetBrains Mono', monospace;
    color: var(--text-muted);
}
.sni-apply-btn {
    padding: 5px 8px !important;
    font-size: 16px !important;
    line-height: 1;
}
.sni-modal-close {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 4px 6px;
    border-radius: 6px;
    font-size: 18px;
    transition: color .15s;
    line-height: 1;
}
.sni-modal-close:hover { color: var(--text-primary); }
</style>

