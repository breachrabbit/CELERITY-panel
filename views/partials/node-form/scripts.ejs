function isCriticalLogLine(line) {
    const text = String(line || '');
    const lower = text.toLowerCase();
    if (text.includes('❌')) return true;
    if (/\b(fatal|panic|exception|traceback)\b/i.test(text)) return true;
    if (/\b(exit code|failed|error:|permission denied|command not found|connection refused|no route to host)\b/i.test(text)) return true;
    if (lower.includes('[stderr]') && /\berror\b/i.test(text)) return true;
    return false;
}

function isWarningLogLine(line) {
    const text = String(line || '');
    if (text.includes('⚠')) return true;
    if (/\bwarning\b/i.test(text)) return true;
    return false;
}

function isSuccessLogLine(line) {
    const text = String(line || '');
    return text.includes('✓') || /\b(done|success|completed)\b/i.test(text);
}

function showLogs(logs) {
    const container = document.getElementById('logsContainer');
    const output = document.getElementById('logsOutput');
    container.style.display = 'block';
    let html = '';
    if (Array.isArray(logs)) {
        html = logs.map(line => {
            const text = String(line || '');
            if (isCriticalLogLine(text)) return '<span class="error">' + escapeHtml(text) + '</span>';
            if (text.includes('[STDERR]')) return '<span class="stderr">' + escapeHtml(text) + '</span>';
            if (isWarningLogLine(text)) return '<span class="warning">' + escapeHtml(text) + '</span>';
            if (isSuccessLogLine(text)) return '<span class="success">' + escapeHtml(text) + '</span>';
            return escapeHtml(line);
        }).join('\n');
    } else {
        html = escapeHtml(String(logs));
    }
    output.innerHTML = html;
    output.scrollTop = output.scrollHeight;
}

function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

function clearLogs() {
    document.getElementById('logsContainer').style.display = 'none';
    document.getElementById('logsOutput').innerHTML = '';
}

function humanizeOnboardingStep(step) {
    return String(step || '')
        .trim()
        .replace(/-/g, ' ')
        .replace(/\b\w/g, (m) => m.toUpperCase()) || 'Setup';
}

function renderOnboardingProgress(statusData) {
    const onboarding = statusData?.onboarding || null;
    if (!onboarding || !onboarding.currentStep) return '';
    const stepLabel = humanizeOnboardingStep(onboarding.currentStep);
    return `<div style="margin-top:8px;opacity:.8;font-size:12px;">${escapeHtml(stepLabel)}</div>`;
}

function initOnboardingStepSelect() {
    const select = document.getElementById('onboardingResumeStep');
    if (!select || select.dataset.ready === '1') return;
    if (!select.querySelector('option[value=""]')) {
        const autoOption = document.createElement('option');
        autoOption.value = '';
        autoOption.textContent = i18n.onboardingResumeStepAuto || 'Auto';
        select.appendChild(autoOption);
    }
    ONBOARDING_STEP_OPTIONS.forEach((step) => {
        const exists = !!select.querySelector(`option[value="${step}"]`);
        if (exists) return;
        const option = document.createElement('option');
        option.value = step;
        option.textContent = humanizeOnboardingStep(step);
        select.appendChild(option);
    });
    select.dataset.ready = '1';
}

function setActionButtonBusy(btn, isBusy, iconClass, label) {
    if (!btn) return;
    btn.disabled = !!isBusy;
    const icon = isBusy ? 'ti ti-loader-2' : iconClass;
    const text = isBusy ? '...' : label;
    btn.innerHTML = '<span class="action-icon"><i class="' + icon + '"></i></span><span>' + escapeHtml(text) + '</span>';
}

async function pollSetupCompletion(runningMessage) {
    const wait = (ms) => new Promise(resolve => setTimeout(resolve, ms));
    const started = Date.now();
    const maxWaitMs = 30 * 60 * 1000;

    while (true) {
        if ((Date.now() - started) > maxWaitMs) {
            throw new Error('Setup timeout: background task did not finish in expected time');
        }

        const statusRes = await fetch('/panel/nodes/<%= node._id %>/setup-status', { cache: 'no-store' });
        const statusData = await statusRes.json();
        const liveLogs = (statusData.onboarding && Array.isArray(statusData.onboarding.logs) && statusData.onboarding.logs.length)
            ? statusData.onboarding.logs
            : statusData.logs;
        if (liveLogs) showLogs(liveLogs);

        if (statusData.state === 'running') {
            const progress = renderOnboardingProgress(statusData);
            document.getElementById('setupResult').innerHTML = '<div class="alert">' + runningMessage + progress + '</div>';
        }

        if (statusData.state === 'running' || statusData.state === 'idle') {
            await wait(2000);
            continue;
        }

        if (statusData.state === 'success') {
            document.getElementById('setupResult').innerHTML = '<div class="alert alert-success"><i class="ti ti-check"></i> ' + (statusData.message || i18n.setupDone || 'Setup completed') + '</div>';
            if (typeof refreshNodeInfo === 'function') {
                try {
                    await refreshNodeInfo();
                } catch (_) {}
            }
        } else {
            const progress = renderOnboardingProgress(statusData);
            document.getElementById('setupResult').innerHTML = '<div class="alert alert-error"><i class="ti ti-x"></i> ' + (statusData.error || i18n.error) + progress + '</div>';
        }
        break;
    }
}

async function startOnboardingAction({ url, payload, runningMessage }) {
    const startRes = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload || {}),
    });
    const startData = await startRes.json();
    if (startData.logs) showLogs(startData.logs);
    if (!startRes.ok && !startData.running) {
        throw new Error(startData.error || i18n.error);
    }
    await pollSetupCompletion(runningMessage);
}

function formatOnboardingJobDate(value) {
    if (!value) return '—';
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return '—';
    return date.toLocaleString();
}

function resolveOnboardingJobMode(job) {
    const setupMode = String(job?.metadata?.setupMode || '').trim().toLowerCase();
    if (setupMode === 'onboarding-full' || setupMode === 'onboarding') return 'onboarding-full';
    if (setupMode === 'legacy') return 'legacy';
    const flow = String(job?.metadata?.flow || '').trim().toLowerCase();
    if (flow === 'durable-onboarding-run-full') return 'onboarding-full';
    if (flow === 'legacy-setup-bridge') return 'legacy';
    if (String(job?.metadata?.bridgeMode || '').trim().toLowerCase() === 'legacy-auto-setup') return 'legacy';
    return '';
}

function getOnboardingJobModeLabel(job) {
    const mode = resolveOnboardingJobMode(job);
    if (mode === 'onboarding-full') return i18n.onboardingModeDurable || 'Durable';
    if (mode === 'legacy') return i18n.onboardingModeLegacy || 'Legacy bridge';
    return i18n.onboardingModeUnknown || 'Unknown';
}

function isLegacyBridgeJob(job) {
    return resolveOnboardingJobMode(job) === 'legacy';
}

function canResumeJob(job) {
    const status = String(job?.status || '').trim().toLowerCase();
    if (!['queued', 'blocked', 'repairable'].includes(status)) return false;
    return !isLegacyBridgeJob(job);
}

function getPreferredResumeStep(job) {
    const states = Array.isArray(job?.stepStates) ? job.stepStates : [];
    const failed = states.find((state) => ['failed', 'blocked'].includes(String(state?.status || '').toLowerCase()));
    return String(failed?.step || job?.currentStep || '').trim();
}

function escapeAttr(value) {
    return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
}

function summarizeStepStates(job) {
    const states = Array.isArray(job?.stepStates) ? job.stepStates : [];
    if (!states.length) return '—';
    const counts = {
        completed: 0,
        running: 0,
        failed: 0,
        blocked: 0,
        pending: 0,
        skipped: 0,
    };
    states.forEach((state) => {
        const key = String(state?.status || 'pending').toLowerCase();
        if (!Object.prototype.hasOwnProperty.call(counts, key)) return;
        counts[key] += 1;
    });
    const parts = [];
    if (counts.completed) parts.push(`ok:${counts.completed}`);
    if (counts.running) parts.push(`run:${counts.running}`);
    if (counts.failed) parts.push(`fail:${counts.failed}`);
    if (counts.blocked) parts.push(`block:${counts.blocked}`);
    if (counts.pending) parts.push(`todo:${counts.pending}`);
    return parts.join(' · ') || '—';
}

function renderStepChips(job) {
    const states = Array.isArray(job?.stepStates) ? job.stepStates : [];
    if (!states.length) return '';
    return states.map((state) => {
        const status = String(state?.status || 'pending').toLowerCase();
        const step = humanizeOnboardingStep(state?.step || '');
        return `<span class="onboarding-step-chip is-${escapeAttr(status)}">${escapeHtml(step)}: ${escapeHtml(status)}</span>`;
    }).join('');
}

function buildOnboardingDiagnosticText(job) {
    const id = String(job?.id || '');
    const lines = [];
    lines.push(`Job: ${id}`);
    lines.push(`Mode: ${getOnboardingJobModeLabel(job)}`);
    lines.push(`Status: ${String(job?.status || 'unknown')}`);
    lines.push(`Current step: ${String(job?.currentStep || 'n/a')}`);
    lines.push(`Updated: ${formatOnboardingJobDate(job?.updatedAt || job?.lastHeartbeatAt || job?.finishedAt || job?.startedAt)}`);
    if (job?.lastError?.message) {
        lines.push(`Error: ${String(job.lastError.message)}`);
    }
    lines.push('');
    lines.push('Step states:');
    (Array.isArray(job?.stepStates) ? job.stepStates : []).forEach((state) => {
        const step = String(state?.step || '');
        const status = String(state?.status || 'pending');
        const attempt = Number(state?.attempt || 0);
        const stepError = String(state?.lastError?.message || '');
        lines.push(`- ${step}: ${status} (attempt ${attempt})${stepError ? ` | ${stepError}` : ''}`);
    });
    lines.push('');
    lines.push('Recent logs:');
    const logs = (Array.isArray(job?.stepLogs) ? job.stepLogs : []).slice(-12);
    if (!logs.length) {
        lines.push('- none');
    } else {
        logs.forEach((log) => {
            const ts = formatOnboardingJobDate(log?.at);
            const step = String(log?.step || '');
            const level = String(log?.level || 'info');
            const message = String(log?.message || '').trim();
            lines.push(`- [${ts}] [${level}] [${step}] ${message}`);
        });
    }
    return lines.join('\n');
}

async function copyOnboardingDiagnostics(jobId) {
    const target = onboardingJobsCache.find((job) => String(job?.id || '') === String(jobId || ''));
    if (!target) return;
    const text = buildOnboardingDiagnosticText(target);
    let copied = false;
    if (navigator.clipboard?.writeText) {
        try {
            await navigator.clipboard.writeText(text);
            copied = true;
        } catch (_) {}
    }
    if (!copied) {
        const fallback = document.createElement('textarea');
        fallback.value = text;
        fallback.style.position = 'fixed';
        fallback.style.opacity = '0';
        document.body.appendChild(fallback);
        fallback.select();
        document.execCommand('copy');
        document.body.removeChild(fallback);
    }
    document.getElementById('setupResult').innerHTML = `<div class="alert alert-success"><i class="ti ti-check"></i> ${escapeHtml(i18n.onboardingCopyDone || 'Diagnostics copied')}</div>`;
}

function useOnboardingJobStep(jobId) {
    const select = document.getElementById('onboardingResumeStep');
    if (!select) return;
    const target = onboardingJobsCache.find((job) => String(job?.id || '') === String(jobId || ''));
    if (!target) return;
    const step = getPreferredResumeStep(target);
    if (!step) return;
    select.value = step;
}

async function resumeOnboardingJob(jobId) {
    const target = onboardingJobsCache.find((job) => String(job?.id || '') === String(jobId || ''));
    if (!target) return;
    if (!confirm(i18n.onboardingResumeConfirm || 'Resume onboarding?')) return;
    if (isLegacyBridgeJob(target)) {
        document.getElementById('setupResult').innerHTML = '<div class="alert alert-error"><i class="ti ti-x"></i> ' + escapeHtml(i18n.onboardingLegacyBridgeHint || 'Legacy bridge job cannot be resumed via onboarding-full') + '</div>';
        return;
    }
    const btn = document.getElementById('btnResumeOnboarding');
    setActionButtonBusy(btn, true, 'ti ti-player-play', i18n.onboardingResume);
    document.getElementById('setupResult').innerHTML = '<div class="alert">' + i18n.onboardingResumeRunning + '</div>';
    try {
        const selectedStep = String(document.getElementById('onboardingResumeStep')?.value || '').trim();
        const preferred = getPreferredResumeStep(target);
        const step = selectedStep || preferred;
        await startOnboardingAction({
            url: '/panel/nodes/<%= node._id %>/onboarding/resume',
            payload: {
                jobId: target.id,
                ...(step ? { step } : {}),
            },
            runningMessage: i18n.onboardingResumeRunning,
        });
    } catch (err) {
        document.getElementById('setupResult').innerHTML = '<div class="alert alert-error"><i class="ti ti-x"></i> ' + err.message + '</div>';
    } finally {
        setActionButtonBusy(btn, false, 'ti ti-player-play', i18n.onboardingResume);
        await loadOnboardingJobs();
    }
}

async function rerunOnboardingStep(jobId) {
    const target = onboardingJobsCache.find((job) => String(job?.id || '') === String(jobId || ''));
    if (!target) return;
    if (isLegacyBridgeJob(target)) {
        document.getElementById('setupResult').innerHTML = '<div class="alert alert-error"><i class="ti ti-x"></i> ' + escapeHtml(i18n.onboardingLegacyBridgeHint || 'Legacy bridge job cannot rerun step via onboarding-full') + '</div>';
        return;
    }

    const selectedStep = String(document.getElementById('onboardingResumeStep')?.value || '').trim();
    const preferred = getPreferredResumeStep(target);
    const step = selectedStep || preferred;
    if (!step) {
        document.getElementById('setupResult').innerHTML = '<div class="alert alert-error"><i class="ti ti-x"></i> ' + escapeHtml(i18n.onboardingUseFailedStep || 'Select step first') + '</div>';
        return;
    }

    if (!confirm((i18n.onboardingRerunStepConfirm || 'Rerun selected onboarding step?') + '\n\n' + step)) return;
    const btn = document.getElementById('btnResumeOnboarding');
    setActionButtonBusy(btn, true, 'ti ti-player-play', i18n.onboardingResume);
    document.getElementById('setupResult').innerHTML = '<div class="alert">' + escapeHtml((i18n.onboardingRerunRunning || 'Running onboarding step rerun...') + ' ' + step) + '</div>';
    try {
        await startOnboardingAction({
            url: '/panel/nodes/<%= node._id %>/onboarding/rerun-step',
            payload: {
                jobId: target.id,
                step,
            },
            runningMessage: i18n.onboardingRerunRunning || i18n.onboardingResumeRunning,
        });
    } catch (err) {
        document.getElementById('setupResult').innerHTML = '<div class="alert alert-error"><i class="ti ti-x"></i> ' + err.message + '</div>';
    } finally {
        setActionButtonBusy(btn, false, 'ti ti-player-play', i18n.onboardingResume);
        await loadOnboardingJobs();
    }
}

function renderOnboardingJobsSummary(jobs) {
    const summary = document.getElementById('onboardingJobsSummary');
    if (!summary) return;
    if (!Array.isArray(jobs) || jobs.length === 0) {
        summary.textContent = i18n.onboardingJobsEmpty;
        return;
    }
    const cards = jobs.slice(0, 6).map((job) => {
        const id = String(job?.id || '').slice(-8) || '—';
        const status = String(job?.status || 'unknown').toLowerCase();
        const modeLabel = getOnboardingJobModeLabel(job);
        const step = humanizeOnboardingStep(job?.currentStep || 'preflight');
        const updated = formatOnboardingJobDate(job?.updatedAt || job?.lastHeartbeatAt || job?.finishedAt || job?.startedAt);
        const errorText = String(job?.lastError?.message || '').trim();
        const canResume = canResumeJob(job);
        const logs = (Array.isArray(job?.stepLogs) ? job.stepLogs : []).slice(-8)
            .map((entry) => {
                const ts = formatOnboardingJobDate(entry?.at);
                const entryStep = humanizeOnboardingStep(entry?.step || '');
                const entryMessage = String(entry?.message || '').trim();
                return `[${ts}] [${entryStep}] ${entryMessage}`;
            });
        const logPreview = logs.length ? logs.join('\n') : (i18n.onboardingNoLogs || 'No logs yet');
        const chips = renderStepChips(job);

        return `
            <div class="onboarding-job-card">
                <div class="onboarding-job-head">
                    <div>
                        <div class="onboarding-job-title">${escapeHtml(i18n.onboardingJobLabel)} #${escapeHtml(id)}</div>
                        <div class="onboarding-job-meta">
                            <div>${escapeHtml(i18n.onboardingStatusLabel)}: ${escapeHtml(status)}</div>
                            <div>${escapeHtml(i18n.onboardingStepLabel)}: ${escapeHtml(step)}</div>
                            <div>${escapeHtml(i18n.onboardingModeLabel || 'Mode')}: ${escapeHtml(modeLabel)}</div>
                            <div>${escapeHtml(i18n.onboardingUpdatedLabel)}: ${escapeHtml(updated)}</div>
                            <div>${escapeHtml(i18n.onboardingStepsSummaryLabel || 'Steps')}: ${escapeHtml(summarizeStepStates(job))}</div>
                        </div>
                    </div>
                    <div class="onboarding-job-actions">
                        <button type="button" class="btn btn-sm" onclick="resumeOnboardingJob('${escapeAttr(job?.id || '')}')" ${canResume ? '' : 'disabled'}>
                            <i class="ti ti-player-play"></i> ${escapeHtml(i18n.onboardingResumeJob || i18n.onboardingResume)}
                        </button>
                        <button type="button" class="btn btn-sm" onclick="useOnboardingJobStep('${escapeAttr(job?.id || '')}')">
                            <i class="ti ti-target-arrow"></i> ${escapeHtml(i18n.onboardingUseFailedStep || 'Use failed step')}
                        </button>
                        <button type="button" class="btn btn-sm" onclick="rerunOnboardingStep('${escapeAttr(job?.id || '')}')" ${isLegacyBridgeJob(job) ? 'disabled' : ''}>
                            <i class="ti ti-repeat"></i> ${escapeHtml(i18n.onboardingRerunStep || 'Rerun step')}
                        </button>
                        <button type="button" class="btn btn-sm" onclick="copyOnboardingDiagnostics('${escapeAttr(job?.id || '')}')">
                            <i class="ti ti-copy"></i> ${escapeHtml(i18n.onboardingCopyDiagnostics || 'Copy diagnostics')}
                        </button>
                    </div>
                </div>
                ${errorText ? `<div class="onboarding-job-error">${escapeHtml(i18n.onboardingErrorLabel)}: ${escapeHtml(errorText)}</div>` : ''}
                ${isLegacyBridgeJob(job) ? `<div class="onboarding-job-hint">${escapeHtml(i18n.onboardingLegacyBridgeHint || 'Legacy bridge mode; use Repair to start durable onboarding')}</div>` : ''}
                <details class="onboarding-job-details">
                    <summary>${escapeHtml(i18n.onboardingDiagnosticsLabel || 'Diagnostics')}</summary>
                    <div class="onboarding-step-states">${chips}</div>
                    <pre class="onboarding-job-log-preview">${escapeHtml(logPreview)}</pre>
                </details>
            </div>
        `;
    });
    summary.innerHTML = cards.join('');
}

async function loadOnboardingJobs() {
    const summary = document.getElementById('onboardingJobsSummary');
    const btn = document.getElementById('btnLoadOnboardingJobs');
    if (summary) summary.textContent = i18n.onboardingJobsLoading;
    if (btn) btn.disabled = true;
    try {
        const res = await fetch('/api/nodes/<%= node._id %>/onboarding/jobs?limit=6', { credentials: 'include' });
        const data = await res.json();
        if (!res.ok) {
            throw new Error(data?.error || i18n.onboardingJobsLoadError);
        }
        onboardingJobsCache = Array.isArray(data?.jobs) ? data.jobs : [];
        renderOnboardingJobsSummary(onboardingJobsCache);
    } catch (err) {
        onboardingJobsCache = [];
        if (summary) summary.innerHTML = '<span class="text-danger">' + escapeHtml((i18n.onboardingJobsLoadError || i18n.error) + ': ' + err.message) + '</span>';
    } finally {
        if (btn) btn.disabled = false;
    }
}

async function setupNode() {
    const confirmMsg = nodeType === 'xray' ? i18n.autoSetupConfirmXray : i18n.autoSetupConfirm;
    if (!confirm(confirmMsg)) return;
    const btn = document.getElementById('btnSetup');
    setActionButtonBusy(btn, true, 'ti ti-settings', i18n.autoSetup);
    document.getElementById('setupResult').innerHTML = '<div class="alert">' + i18n.setupRunning + '</div>';
