async function runHybridSmokeCheck() {
    const btn = document.getElementById('btnHybridSmoke');
    if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<span class="action-icon"><i class="ti ti-loader-2"></i></span><span>...</span>';
    }
    document.getElementById('setupResult').innerHTML = '<div class="alert">' + i18n.hybridSmokeRunning + '</div>';

    try {
        const res = await fetch('/panel/nodes/<%= node._id %>/smoke-check-hybrid', { method: 'POST' });
        const data = await res.json();

        if (Array.isArray(data.logs)) {
            showLogs(data.logs);
        }

        const summary = data?.summary;
        const summaryText = summary
            ? (i18n.hybridSmokeSummary + ': PASS=' + summary.passed + ', FAIL=' + summary.failed)
            : '';

        if (res.ok && data.success) {
            document.getElementById('setupResult').innerHTML = '<div class="alert alert-success"><i class="ti ti-check"></i> ' + i18n.hybridSmokeDone + (summaryText ? ('<br><small>' + summaryText + '</small>') : '') + '</div>';
        } else {
            const errText = data?.error || i18n.hybridSmokeFailed;
            document.getElementById('setupResult').innerHTML = '<div class="alert alert-error"><i class="ti ti-x"></i> ' + errText + (summaryText ? ('<br><small>' + summaryText + '</small>') : '') + '</div>';
        }
    } catch (err) {
        document.getElementById('setupResult').innerHTML = '<div class="alert alert-error"><i class="ti ti-x"></i> ' + i18n.error + ': ' + err.message + '</div>';
    } finally {
        if (btn) {
            btn.disabled = false;
            btn.innerHTML = '<span class="action-icon"><i class="ti ti-heart-rate-monitor"></i></span><span>' + i18n.hybridSmokeCheck + '</span>';
        }
    }
}

