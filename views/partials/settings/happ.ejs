<div class="card" style="margin-top: 1.5rem;">
    <div class="card-header">
        <h2><i class="ti ti-rocket"></i> <%= t('settings.happTitle') %></h2>
        <p class="hint" style="margin:0"><%= t('settings.happDesc') %></p>
    </div>
    <div class="card-body">
        <form method="POST" action="/panel/settings">
            <input type="hidden" name="_subscriptionSettings" value="1">
            <input type="hidden" name="_happSettings" value="1">
            <input type="hidden" name="subscription.supportUrl" value="<%= settings?.subscription?.supportUrl || '' %>">
            <input type="hidden" name="subscription.webPageUrl" value="<%= settings?.subscription?.webPageUrl || '' %>">
            <input type="hidden" name="subscription.logoUrl" value="<%= settings?.subscription?.logoUrl || '' %>">
            <input type="hidden" name="subscription.pageTitle" value="<%= settings?.subscription?.pageTitle || '' %>">
            <input type="hidden" name="subscription.updateInterval" value="<%= settings?.subscription?.updateInterval ?? 12 %>">
            <input type="hidden" name="subscription.buttonsJson" value="<%= JSON.stringify(settings?.subscription?.buttons || []) %>">

            <div class="form-group" style="margin-bottom: 1.25rem;">
                <label><%= t('settings.happAnnounce') %></label>
                <textarea name="subscription.happ.announce" maxlength="200" rows="3"
                          style="width:100%; resize:vertical;"><%= settings?.subscription?.happ?.announce || '' %></textarea>
                <small class="hint"><%= t('settings.happAnnounceHint') %></small>
            </div>

            <details id="happAdvanced" style="margin-bottom:1.25rem;">
                <summary style="cursor:pointer; font-weight:600;"><%= t('settings.happAdvancedToggle') %></summary>
                <p class="hint" style="margin-top:8px;"><%= t('settings.happAdvancedHint') %></p>

                <div class="form-group" style="margin-top: 1rem;">
                    <label><%= t('settings.happInfoText') %></label>
                    <textarea name="subscription.happ.infoText" maxlength="200" rows="3"
                              style="width:100%; resize:vertical;"
                              placeholder="<%= t('settings.happInfoTextPlaceholder') %>"><%= settings?.subscription?.happ?.infoText || '' %></textarea>
                    <small class="hint"><%= t('settings.happInfoTextHint') %></small>
                </div>

                <details style="margin-top: 1rem; padding: 0.85rem 1rem; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-secondary);">
                    <summary style="cursor:pointer; font-weight:600;"><%= t('settings.happDisplayTitle') %></summary>
                    <div style="margin-top:0.85rem;">
                        <div class="settings-grid">
                            <label class="checkbox-label">
                                <input type="checkbox" name="subscription.happ.display.showTrafficProgress" <%= settings?.subscription?.happ?.display?.showTrafficProgress !== false ? 'checked' : '' %>>
                                <span><%= t('settings.happDisplayTrafficProgress') %></span>
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" name="subscription.happ.display.showTrafficDetails" <%= settings?.subscription?.happ?.display?.showTrafficDetails !== false ? 'checked' : '' %>>
                                <span><%= t('settings.happDisplayTrafficDetails') %></span>
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" name="subscription.happ.display.showDevices" <%= settings?.subscription?.happ?.display?.showDevices !== false ? 'checked' : '' %>>
                                <span><%= t('settings.happDisplayDevices') %></span>
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" name="subscription.happ.display.showSupportStatus" <%= settings?.subscription?.happ?.display?.showSupportStatus !== false ? 'checked' : '' %>>
                                <span><%= t('settings.happDisplaySupportStatus') %></span>
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" name="subscription.happ.display.showSupportPeriod" <%= settings?.subscription?.happ?.display?.showSupportPeriod !== false ? 'checked' : '' %>>
                                <span><%= t('settings.happDisplaySupportPeriod') %></span>
                            </label>
                        </div>
                        <small class="hint"><%= t('settings.happDisplayHint') %></small>
                    </div>
                </details>

                <details style="margin-top: 1rem; padding: 0.85rem 1rem; border: 1px solid var(--border); border-radius: 8px; background: var(--bg-secondary);">
                    <summary style="cursor:pointer; font-weight:600;"><%= t('settings.happSupportTitle') %></summary>
                    <div style="margin-top:0.85rem;">
                        <label class="checkbox-label" style="margin-bottom: 1rem;">
                            <input type="checkbox" name="subscription.happ.support.enabled" <%= settings?.subscription?.happ?.support?.enabled !== false ? 'checked' : '' %>>
                            <span><%= t('settings.happSupportEnabled') %></span>
                        </label>

                        <div class="settings-grid">
                            <div class="form-group">
                                <label><%= t('settings.happSupportAmount') %></label>
                                <input type="number" name="subscription.happ.support.amountRub"
                                       value="<%= settings?.subscription?.happ?.support?.amountRub ?? 200 %>"
                                       min="0" step="1">
                            </div>
                            <div class="form-group">
                                <label><%= t('settings.happSupportPeriodDays') %></label>
                                <input type="number" name="subscription.happ.support.periodDays"
                                       value="<%= settings?.subscription?.happ?.support?.periodDays ?? 30 %>"
                                       min="1" step="1">
                            </div>
                        </div>

                        <div class="settings-grid">
                            <div class="form-group">
                                <label><%= t('settings.happSupportButtonText') %></label>
                                <input type="text" name="subscription.happ.support.buttonText"
                                       value="<%= settings?.subscription?.happ?.support?.buttonText || '' %>"
                                       maxlength="40" placeholder="<%= t('settings.happSupportButtonTextPlaceholder') %>">
                            </div>
                            <div class="form-group">
                                <label><%= t('settings.happSupportButtonLink') %></label>
                                <input type="text" name="subscription.happ.support.buttonLink"
                                       value="<%= settings?.subscription?.happ?.support?.buttonLink || '' %>"
                                       placeholder="https://example.com/support">
                            </div>
                        </div>

                        <div class="form-group">
                            <label><%= t('settings.happSupportNeutralText') %></label>
                            <textarea name="subscription.happ.support.neutralText" maxlength="200" rows="3"
                                      style="width:100%; resize:vertical;"><%= settings?.subscription?.happ?.support?.neutralText || '' %></textarea>
                        </div>

                        <div class="form-group">
                            <label><%= t('settings.happSupportActiveText') %></label>
                            <textarea name="subscription.happ.support.activeText" maxlength="200" rows="3"
                                      style="width:100%; resize:vertical;"><%= settings?.subscription?.happ?.support?.activeText || '' %></textarea>
                        </div>

                        <div class="form-group">
                            <label><%= t('settings.happSupportOverdueText') %></label>
                            <textarea name="subscription.happ.support.overdueText" maxlength="200" rows="3"
                                      style="width:100%; resize:vertical;"><%= settings?.subscription?.happ?.support?.overdueText || '' %></textarea>
                        </div>
                        <small class="hint"><%= t('settings.happSupportHint') %></small>
                    </div>
                </details>

                <div class="settings-grid" style="margin-top:1rem;">
                    <div class="form-group">
                        <label><%= t('settings.happInfoColor') %></label>
                        <select name="subscription.happ.infoColor">
                            <option value="blue" <%= (!settings?.subscription?.happ?.infoColor || settings?.subscription?.happ?.infoColor === 'blue') ? 'selected' : '' %>><%= t('settings.happInfoColorBlue') %></option>
                            <option value="green" <%= settings?.subscription?.happ?.infoColor === 'green' ? 'selected' : '' %>><%= t('settings.happInfoColorGreen') %></option>
                            <option value="red" <%= settings?.subscription?.happ?.infoColor === 'red' ? 'selected' : '' %>><%= t('settings.happInfoColorRed') %></option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label><%= t('settings.happInfoButtonText') %></label>
                        <input type="text" name="subscription.happ.infoButtonText"
                               value="<%= settings?.subscription?.happ?.infoButtonText || '' %>"
                               maxlength="25" placeholder="<%= t('settings.happInfoButtonTextPlaceholder') %>">
                    </div>
                </div>

                <div class="form-group">
                    <label><%= t('settings.happInfoButtonLink') %></label>
                    <input type="text" name="subscription.happ.infoButtonLink"
                           value="<%= settings?.subscription?.happ?.infoButtonLink || '' %>"
                           placeholder="https://t.me/yoursupport">
                </div>

                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" name="subscription.happ.expireBannerEnabled" <%= settings?.subscription?.happ?.expireBannerEnabled ? 'checked' : '' %>>
                        <span><%= t('settings.happExpireBanner') %></span>
                    </label>
                    <small class="hint"><%= t('settings.happExpireBannerHint') %></small>
                </div>

                <div class="form-group">
                    <label><%= t('settings.happExpireButtonLink') %></label>
                    <input type="text" name="subscription.happ.expireButtonLink"
                           value="<%= settings?.subscription?.happ?.expireButtonLink || '' %>"
                           placeholder="https://t.me/yoursupport">
                </div>

                <div class="settings-grid">
                    <label class="checkbox-label">
                        <input type="checkbox" name="subscription.happ.hideSettings" <%= settings?.subscription?.happ?.hideSettings ? 'checked' : '' %>>
                        <span><%= t('settings.happHideSettings') %></span>
                    </label>
                    <label class="checkbox-label">
                        <input type="checkbox" name="subscription.happ.notifyExpire" <%= settings?.subscription?.happ?.notifyExpire ? 'checked' : '' %>>
                        <span><%= t('settings.happNotifyExpire') %></span>
                    </label>
                    <label class="checkbox-label">
                        <input type="checkbox" name="subscription.happ.alwaysHwid" <%= settings?.subscription?.happ?.alwaysHwid ? 'checked' : '' %>>
                        <span><%= t('settings.happAlwaysHwid') %></span>
                    </label>
                </div>
                <small class="hint" style="display:block; margin-top:0.4rem;"><%= t('settings.happAlwaysHwidHint') %></small>

                <div class="settings-grid" style="margin-top:1rem;">
                    <div class="form-group">
                        <label><%= t('settings.happPingType') %></label>
                        <select name="subscription.happ.pingType" id="happPingType" onchange="document.getElementById('happPingUrlWrap').style.display = ['proxy','proxy-head'].includes(this.value) ? '' : 'none'">
                            <option value="" <%= (!settings?.subscription?.happ?.pingType) ? 'selected' : '' %>><%= t('settings.happPingTypeAuto') %></option>
                            <option value="proxy" <%= settings?.subscription?.happ?.pingType === 'proxy' ? 'selected' : '' %>><%= t('settings.happPingTypeProxy') %></option>
                            <option value="proxy-head" <%= settings?.subscription?.happ?.pingType === 'proxy-head' ? 'selected' : '' %>><%= t('settings.happPingTypeProxyHead') %></option>
                            <option value="tcp" <%= settings?.subscription?.happ?.pingType === 'tcp' ? 'selected' : '' %>><%= t('settings.happPingTypeTcp') %></option>
                            <option value="icmp" <%= settings?.subscription?.happ?.pingType === 'icmp' ? 'selected' : '' %>><%= t('settings.happPingTypeIcmp') %></option>
                        </select>
                        <small class="hint"><%= t('settings.happPingTypeHint') %></small>
                    </div>
                    <div class="form-group" id="happPingUrlWrap" style="<%= ['proxy','proxy-head'].includes(settings?.subscription?.happ?.pingType) ? '' : 'display:none' %>">
                        <label><%= t('settings.happPingUrl') %></label>
                        <input type="url" name="subscription.happ.pingUrl"
                               value="<%= settings?.subscription?.happ?.pingUrl || '' %>"
                               placeholder="https://cp.cloudflare.com/generate_204">
                        <small class="hint"><%= t('settings.happPingUrlHint') %></small>
                    </div>
                </div>

                <div class="form-group" style="margin-top:1rem;">
                    <label><%= t('settings.happColorProfile') %></label>
                    <input type="hidden" name="subscription.happ.colorProfile" value="<%= settings?.subscription?.happ?.colorProfile || '' %>">
                    <div class="hint" style="padding:0.85rem 1rem; border:1px dashed var(--border); border-radius:8px; background:var(--bg-secondary);">
                        <%= t('settings.happColorProfileDisabled') %>
                    </div>
                    <small class="hint"><%= t('settings.happColorProfileHint') %></small>
                </div>
            </details>

            <div style="display:flex; justify-content:flex-end;">
                <button type="submit" class="btn btn-primary">
                    <i class="ti ti-device-floppy"></i> <%= t('common.save') %>
                </button>
            </div>
        </form>
    </div>
</div>
